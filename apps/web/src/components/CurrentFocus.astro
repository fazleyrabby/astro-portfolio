---
const focus = [
  {
    label: "Project:",
    detail: "Building a headless e-commerce backend with Laravel & Meilisearch."
  },
  {
    label: "Learning:",
    detail: "Advanced Docker orchestration and Kubernetes for Laravel environments."
  },
  {
    label: "OSS:",
    detail: "Refining a multi-tenant SaaS starter kit for the Laravel ecosystem."
  }
];
---
<section id="focus" class="reveal py-16">
  <div class="mb-10">
    <span class="section-label">Learning & Building</span>
    <h2 class="text-3xl md:text-5xl font-bold font-display text-[var(--text-primary)] mb-2">Currently Building</h2>
    <p class="text-[var(--text-secondary)] max-w-xl">A glimpse into what I'm experimenting with right now.</p>
  </div>

  <ul class="space-y-4 max-w-2xl">
    {focus.map(f => (
      <li class="flex items-baseline gap-3">
        <span class="font-medium text-sm text-[var(--text-primary)]">{f.label}</span>
        <span class="text-sm text-[var(--text-secondary)]">{f.detail}</span>
      </li>
    ))}
  </ul>
</section>
