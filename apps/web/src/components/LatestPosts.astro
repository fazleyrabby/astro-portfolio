---
import { supabase } from '@lib/supabase';
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { data } = await supabase
  .from('posts')
  .select('slug, title, published_at')
  .eq('status', 'published')
  // Assume 'lang' column exists in Supabase. If not, this might fail until added.
  .eq('lang', lang)
  .order('published_at', { ascending: false })
  .limit(3);
const latestPosts = data || [];
---

<section id="posts" class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center gap-6 mb-12">
      <div>
        <span class="section-label">{t('posts.label')}</span>
        <h2 class="reveal-heading text-[var(--text-primary)] font-display font-bold text-[clamp(1.8rem,5vw,2.5rem)] leading-tight">{t('posts.title')}</h2>
      </div>
      <div class="flex-1 hidden md:block h-[1px] bg-accent opacity-20 dark:opacity-30"></div>
    </div>

    <div class="post-list border-t border-border">
      {latestPosts.map((post, i) => (
        <a href={translatePath(`/posts/${post.slug}`)} class="post-row flex flex-col sm:flex-row sm:items-center py-4 sm:py-3 border-b border-border group transition-all duration-300 hover:bg-[var(--accent-dim)] hover:pl-4">
          <div class="flex items-start gap-4 sm:gap-6 flex-1 min-w-0">
            <span class="post-number font-mono text-[0.7rem] text-[var(--text-muted)] group-hover:text-[var(--accent)] transition-colors shrink-0">
              {lang === 'bn' ? 'বিএন' : 'BN'}-0{i + 1}
            </span>
            <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-6 min-w-0">
              <span class="post-date font-mono text-[0.68rem] text-[var(--text-muted)] shrink-0">
                {post.published_at ? new Date(post.published_at).toLocaleDateString(lang === 'bn' ? 'bn-BD' : 'en-US', { month: 'short', day: '2-digit', year: 'numeric' }) : t('posts.unknown')}
              </span>
              <span class="post-title font-display font-semibold text-[1.02rem] text-[var(--text-primary)] group-hover:text-[var(--text-primary)] truncate">
                {post.title}
              </span>
            </div>
          </div>
          <span class="post-arrow font-mono text-[var(--text-secondary)] group-hover:text-[var(--accent)] group-hover:translate-x-1 transition-all mt-2 sm:mt-0 ml-auto sm:ml-0 hidden sm:inline-block">→</span>
        </a>
      ))}
    </div>

    {latestPosts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-[var(--text-muted)] font-mono text-xs">{t('posts.empty')}</p>
      </div>
    )}

    {latestPosts.length > 0 && (
      <div class="mt-6 text-center">
        <a href="/posts" class="btn-ghost">{t('posts.showMore')}</a>
      </div>
    )}
  </div>
</section>
