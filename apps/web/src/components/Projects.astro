---
import { getCollection } from 'astro:content';
import ProjectCard from "./ProjectCard.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { type = "home" } = Astro.props;
const allProjects = await getCollection('projects');
const localizedProjects = allProjects.filter(p => (p.data.lang || 'en') === lang && !p.data.hidden);
localizedProjects.sort((a, b) => (a.data.position || 0) - (b.data.position || 0));

const projects = type === "home" 
  ? localizedProjects.slice(0, 4) 
  : localizedProjects;
---

<section id="projects" class="projects-panel">
  <div class="panel-header">
    <div class="panel-title">
      <span>{t('projects.title').toUpperCase()}</span>
    </div>
  </div>

  <div class={`grid grid-cols-1 md:grid-cols-2 ${type === "home" ? "lg:grid-cols-4" : "lg:grid-cols-3"} gap-4 mt-3`}>
    {projects.map((project, index) => (
      <ProjectCard project={project} index={index} isHome={type === "home"} />
    ))}
  </div>

  {type === "home" && localizedProjects.length > 4 && (
    <div class="mt-4 text-center">
      <a href="/projects" class="btn-ghost group">
        {t('projects.viewAll')}
        <span class="inline-block transition-transform group-hover:translate-x-1 ml-1">→</span>
      </a>
    </div>
  )}
</section>

<style>
  .projects-panel {
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    box-shadow: var(--shadow-main);
    transition: all var(--t-base) ease;
  }
  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .panel-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
  }


</style>
