---
const { title, subtitle, id, class: className } = Astro.props;
---
<section id={id} class={`reveal py-16 ${className || ""}`}>
  <div class="mb-10">
    <h2 class="text-3xl md:text-5xl font-bold font-display text-[var(--text-primary)] mb-2">
      {title}
    </h2>
    {subtitle && (
      <p class="text-[var(--text-secondary)] max-w-xl">{subtitle}</p>
    )}
  </div>
  <slot />
</section>
