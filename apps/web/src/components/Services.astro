---
const services = [
  {
    title: "Laravel Development",
    desc: "Custom Laravel applications, SaaS platforms, admin panels, and modular backend systems."
  },
  {
    title: "REST API Development",
    desc: "Designing and building clean, versioned REST APIs for web and mobile clients."
  },
  {
    title: "Payment Integration",
    desc: "Integrating payment gateways into Laravel apps — multi-gateway abstraction, webhooks, transaction management."
  },
  {
    title: "Performance & Optimization",
    desc: "Query optimization, version upgrades, and caching strategies for production Laravel codebases."
  }
]
---
<section id="services" class="reveal py-16">
  <div class="mb-10">
    <span class="section-label">What I Offer</span>
    <h2 class="text-3xl md:text-5xl font-bold font-display text-[var(--text-primary)] mb-2">Services</h2>
    <p class="text-[var(--text-secondary)] max-w-xl">What I build and how I can help your project.</p>
  </div>

  <div class="grid sm:grid-cols-2 gap-4">
    {services.map(s => (
      <div class="border border-[var(--border)] rounded-xl p-5
                  hover:border-[var(--accent)] transition-colors">
        <h3 class="font-medium mb-2 text-[var(--text-primary)]">{s.title}</h3>
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{s.desc}</p>
      </div>
    ))}
  </div>
</section>
