---
import { getCollection } from "astro:content";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = await getCollection("projects");
const localized = projects.filter((p) => (p.data.lang || "en") === lang && !p.data.hidden);
const totalCommits = localized.reduce((s, p) => s + (p.data.commits || 0), 0);
const startYear = 2021;
const years = new Date().getFullYear() - startYear;

const meta = [
  { k: "EXP", v: `${years}+ yrs` },
  { k: "PROJECTS", v: `${localized.length}` },
  { k: "COMMITS", v: totalCommits > 0 ? `${(totalCommits / 1000).toFixed(1)}k+` : "—" },
  { k: "LOC", v: "Chittagong, BD · UTC+6" },
  { k: "STACK", v: "Laravel / PHP / MySQL" },
  { k: "INFRA", v: "Docker / VPS / Redis" },
];
---

<section class="identity-strip">
  <div class="strip-row strip-row--top">
    <div class="strip-id">
      <div class="badge">
        <span class="badge-dot"></span>
        {t("hero.available")}
      </div>
      <h1 class="strip-name">{t("hero.name") || "Fazley Rabbi"}</h1>
      <p class="strip-role">Backend & Distributed Systems Engineer</p>
      <p class="strip-tagline">{t("hero.tagline")}</p>
    </div>

    <div class="strip-actions">
      <a href="/resume" class="strip-btn strip-btn--primary">Resume</a>
      <a href="#projects" class="strip-btn">Projects</a>
      <a href="mailto:fazley111@gmail.com" class="strip-btn">Contact</a>
      <div class="strip-links">
        <a href="https://github.com/fazleyrabby" target="_blank" rel="noreferrer">GH</a>
        <span class="dot">·</span>
        <a href="https://www.linkedin.com/in/fazley-rabby/" target="_blank" rel="noreferrer">LN</a>
        <span class="dot">·</span>
        <a href="https://fazleyrabby.xyz" target="_blank" rel="noreferrer">SITE</a>
      </div>
    </div>
  </div>

  <table class="strip-row--meta">
    <tbody>
      <tr class="meta-head-row">
        {meta.map((m) => <th>{m.k}</th>)}
      </tr>
      <tr class="meta-val-row">
        {meta.map((m) => <td data-k={m.k}>{m.v}</td>)}
      </tr>
    </tbody>
  </table>
</section>

<style>
  .identity-strip {
    border: none;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .strip-row--top {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 20px;
    align-items: end;
  }
  @media (max-width: 768px) {
    .strip-row--top { grid-template-columns: 1fr; align-items: start; }
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--border);
    background: var(--accent-dim);
    padding: 2px 10px;
    border-radius: 999px;
    width: fit-content;
    margin-bottom: 8px;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .strip-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.6rem, 2.6vw, 2.2rem);
    line-height: 1.05;
    color: var(--text-primary);
    margin: 0 0 4px;
  }
  .strip-role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 8px;
  }
  .strip-tagline {
    font-family: var(--font-serif, var(--font-sans));
    font-style: italic;
    font-size: 0.92rem;
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.5;
    margin: 0;
  }
  .strip-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
  }
  @media (max-width: 768px) {
    .strip-actions { align-items: flex-start; }
  }
  .strip-actions > div,
  .strip-actions {
    display: flex;
    flex-wrap: wrap;
  }
  .strip-actions {
    flex-direction: row;
    gap: 8px;
    align-items: center;
  }
  .strip-btn {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text-primary);
    background: var(--bg-surface);
    transition: all 0.2s ease;
  }
  .strip-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .strip-btn--primary {
    background: var(--accent);
    color: var(--bg-base);
    border-color: var(--accent);
  }
  .strip-btn--primary:hover {
    background: transparent;
    color: var(--accent);
  }
  .strip-links {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-left: 8px;
  }
  .strip-links a:hover { color: var(--accent); }
  .strip-links .dot { color: var(--border); }

  .strip-row--meta {
    width: calc(100% + 32px);
    margin-left: -16px;
    margin-right: -16px;
    border-collapse: collapse;
    table-layout: auto;
    margin-top: 4px;
    border-top: 1px solid var(--grid-line);
    border-bottom: 1px solid var(--grid-line);
    border-left: none;
    border-right: none;
  }
  .strip-row--meta th,
  .strip-row--meta td {
    border: 1px solid var(--grid-line);
    padding: 8px 14px;
    text-align: left;
    min-width: 0;
    white-space: normal;
    word-break: break-word;
    vertical-align: middle;
  }
  .strip-row--meta th {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: color-mix(in srgb, var(--text-primary) 3%, var(--bg-base));
  }
  .strip-row--meta td {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  @media (max-width: 1024px) {
    .strip-row--meta,
    .strip-row--meta tbody,
    .strip-row--meta tr { display: block; }
    .strip-row--meta tr { display: grid; grid-template-columns: repeat(3, 1fr); }
    .meta-head-row { display: none !important; }
    .strip-row--meta td {
      display: flex;
      flex-direction: column;
      gap: 4px;
      white-space: normal;
    }
    .strip-row--meta td::before {
      content: attr(data-k);
      font-size: 0.55rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      font-weight: 700;
    }
  }
  @media (max-width: 540px) {
    .strip-row--meta tr { grid-template-columns: repeat(2, 1fr); }
  }
  .meta-k {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    line-height: 1;
  }
  .meta-v {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
