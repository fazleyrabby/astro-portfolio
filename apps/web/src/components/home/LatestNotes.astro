---
import { supabase } from "@lib/supabase";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

const { data, error } = await supabase
  .from("posts")
  .select("slug, title, published_at")
  .eq("status", "published")
  .eq("lang", lang)
  .order("published_at", { ascending: false })
  .limit(8);

if (error) console.error("LatestNotes supabase error:", error);
const posts = data || [];
---

<section class="notes-panel">
  <div class="panel-head">
    <span class="panel-title">LATEST ENGINEERING NOTES</span>
    <a href="/posts" class="panel-link">All notes →</a>
  </div>

  {posts.length === 0 ? (
    <div class="empty">{t("posts.empty")}</div>
  ) : (
    <ul class="notes-list">
      {posts.map((p, i) => (
        <li>
          <a href={tp(`/posts/${p.slug}`)} class="note-row">
            <span class="note-idx">{String(i + 1).padStart(2, "0")}</span>
            <span class="note-date">
              {p.published_at
                ? new Date(p.published_at).toLocaleDateString(lang === "bn" ? "bn-BD" : "en-US", {
                    month: "short",
                    day: "2-digit",
                    year: "numeric",
                  })
                : "—"}
            </span>
            <span class="note-title">{p.title}</span>
            <span class="note-arrow">→</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</section>

<style>
  .notes-panel {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    box-shadow: var(--shadow-main);
    padding: 16px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .notes-list { flex: 1; }
  .panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 8px;
  }
  .panel-title {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }
  .panel-link {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  .panel-link:hover { color: var(--accent); }

  .notes-list {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .notes-list li { display: flex; flex: 1; }
  .note-row {
    display: grid;
    grid-template-columns: 32px 92px 1fr 16px;
    gap: 12px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    transition: padding 0.2s ease, background 0.2s ease;
    width: 100%;
  }
  .notes-list li:last-child .note-row { border-bottom: none; }
  .note-row:hover {
    padding-left: 8px;
    background: var(--accent-dim);
  }
  .note-idx {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--text-muted);
  }
  .note-row:hover .note-idx { color: var(--accent); }
  .note-date {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--text-muted);
  }
  .note-title {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-primary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .note-cat {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    padding: 2px 6px;
    border: 1px solid var(--border);
    border-radius: 3px;
  }
  .note-arrow {
    font-family: var(--font-mono);
    color: var(--text-muted);
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .note-row:hover .note-arrow {
    color: var(--accent);
    transform: translateX(3px);
  }
  .empty {
    padding: 20px;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  @media (max-width: 640px) {
    .note-row { grid-template-columns: 28px 1fr auto; }
    .note-date { display: none; }
  }
</style>
