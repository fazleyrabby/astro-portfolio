---
import MainLayout from "./MainLayout.astro";
import { Image } from "astro:assets";
import moment from "moment";
const { frontmatter } = Astro.props;
---

<MainLayout 
  title={frontmatter.title} 
  ogTitle={frontmatter.title}
  ogDescription={frontmatter.title}
  ogImage={frontmatter.thumbnail}
  ogType="article"
>
  <div class="container mx-auto w-full px-4 md:px-8 py-20">
    <section class="max-w-4xl mx-auto">
      {frontmatter.thumbnail && (
        <div class="rounded-sm overflow-hidden border border-[var(--border)] mb-12">
          <Image
            src={frontmatter.thumbnail}
            class="object-cover w-full h-[300px] md:h-[450px]"
            alt={frontmatter.title}
            width={1200} height={600}
          />
        </div>
      )}
      
      <article class="prose prose-neutral dark:prose-invert max-w-none prose-headings:font-display prose-p:leading-relaxed prose-p:text-[var(--text-secondary)] prose-strong:text-[var(--text-primary)] prose-strong:font-semibold prose-li:text-[var(--text-secondary)] prose-blockquote:text-[var(--text-secondary)] prose-blockquote:border-[var(--accent)]">
        <header class="mb-12 text-center">
          <div class="font-mono text-[0.7rem] uppercase tracking-widest text-[var(--text-muted)] mb-4">
            {moment(frontmatter.date).format("MMMM D, YYYY")}
          </div>
          <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-[var(--text-primary)] leading-tight">
            {frontmatter.title}
          </h1>
        </header>

        <div id="article-content" class="mt-16">
          <slot />
        </div>
      </article>
    </section>
  </div>
</MainLayout>

<script>
  // Copy button functionality for code blocks
  document.querySelectorAll('pre').forEach(pre => {
    const code = pre.querySelector('code');
    if (!code) return;
    
    const langClass = Array.from(code.classList).find(c => c.startsWith('language-'));
    const lang = langClass ? langClass.replace('language-', '') : 'text';
    const displayLang = lang.toUpperCase();
    
    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper group relative my-6 rounded-lg border border-[var(--border)] bg-[var(--bg-card)] overflow-hidden';
    
    const header = document.createElement('div');
    header.className = 'code-header flex items-center justify-between px-4 py-2 bg-[var(--bg-elevated)] border-b border-[var(--border)]';
    header.innerHTML = `
      <div class="flex items-center gap-2">
        <span class="text-[0.65rem] font-mono font-semibold px-2 py-0.5 rounded bg-[var(--accent)]/10 text-[var(--accent)]">${displayLang}</span>
      </div>
      <button class="copy-btn text-[0.65rem] font-mono px-2 py-0.5 rounded bg-[var(--bg-elevated)] border border-[var(--border)] text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:border-[var(--accent)] transition-all opacity-0 group-hover:opacity-100">Copy</button>
    `;
    
    pre.parentNode.insertBefore(wrapper, pre);
    wrapper.appendChild(header);
    wrapper.appendChild(pre);
    pre.className = '!mt-0 !rounded-none !border-0 overflow-x-auto p-4 text-sm leading-relaxed';
    
    const btn = header.querySelector('.copy-btn');
    btn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(code.textContent || '');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    });
  });
</script>

<style is:global>
  #article-content pre {
    margin: 0;
    border-radius: 0;
    border: none;
  }
  #article-content .code-block-wrapper {
    position: relative;
  }
  #article-content pre code {
    display: block;
  }
</style>
