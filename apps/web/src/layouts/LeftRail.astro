---
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Get current path to highlight active state
const currentPathname = Astro.url.pathname;

const navItems = [
    { 
      href: translatePath("/"), 
      label: t('nav.home'), 
      icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
      active: currentPathname === translatePath("/") || currentPathname === `${translatePath("/")}/`
    },
    { 
      href: translatePath("/projects/"), 
      label: t('nav.work'), 
      icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>`,
      active: currentPathname.includes("/projects")
    },
    { 
      href: translatePath("/posts/"), 
      label: t('nav.blog'), 
      icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
      active: currentPathname.includes("/posts")
    },
    { 
      href: translatePath("/uses/"), 
      label: t('nav.uses'), 
      icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
      active: currentPathname.includes("/uses")
    },
    { 
      href: translatePath("/resume/"), 
      label: t('nav.resume'), 
      icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z"/></svg>`,
      active: currentPathname.includes("/resume")
    },
    { 
      href: translatePath("/about/"), 
      label: t('nav.contact'), 
      icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>`,
      active: currentPathname.includes("/about")
    }
];
---

<aside class="left-rail flex-col justify-between items-center border-r border-[var(--border)] bg-[var(--bg-base)] py-6 z-40 hidden md:flex w-[76px] shrink-0 h-screen sticky top-0">
  <!-- Top: Logo & Status -->
  <div class="flex flex-col items-center gap-6 w-full">
    <a href={translatePath("/")} class="font-display font-bold text-xl text-[var(--text-primary)] hover:text-[var(--accent)] transition-colors">
      F<span class="text-[var(--accent)]">.</span>
    </a>
    
    <!-- Pulse Status Indicator -->
    <div class="status-indicator-dot flex items-center justify-center relative w-8 h-8 rounded-full bg-[var(--accent-dim)] group cursor-help" title={t('status.available')}>
      <span class="w-2.5 h-2.5 rounded-full bg-[var(--accent)] animate-pulse"></span>
      <!-- Tooltip -->
      <span class="absolute left-14 bg-[var(--bg-card)] border border-[var(--border)] text-[0.65rem] text-[var(--text-primary)] rounded px-2 py-0.5 opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity whitespace-nowrap font-mono">
        {t('status.available')}
      </span>
    </div>
  </div>

  <!-- Middle: Nav Icons -->
  <nav class="flex flex-col gap-4 w-full px-2">
    {navItems.map((item) => (
      <a href={item.href} 
         class={`rail-item flex flex-col items-center justify-center py-2.5 rounded-md text-[var(--text-secondary)] hover:text-[var(--accent)] hover:bg-[var(--accent-dim)] transition-all relative group ${item.active ? 'text-[var(--accent)] bg-[var(--accent-dim)]' : ''}`}
         aria-label={item.label}>
        <Fragment set:html={item.icon} />
        <!-- Tooltip -->
        <span class="absolute left-16 bg-[var(--bg-card)] border border-[var(--border)] text-[0.65rem] text-[var(--text-primary)] rounded px-2 py-0.5 opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity whitespace-nowrap font-mono z-50">
          {item.label}
        </span>
      </a>
    ))}
  </nav>

  <!-- Bottom: Theme Selector -->
  <div class="flex flex-col items-center gap-4 w-full px-2">
    <!-- Lang Toggle Slot -->
    <slot name="lang-toggles" />
  </div>
</aside>

<style>
  .left-rail {
    transition: background-color var(--t-base), border-color var(--t-base);
  }
  .rail-item:hover {
    transform: translateY(-1px);
  }
</style>
