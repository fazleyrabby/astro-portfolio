---
import MainLayout from "@layouts/MainLayout.astro";
import Github from "@components/Icons/Github.astro";
import Youtube from "@components/Icons/Youtube.astro";
import Email from "@components/Icons/Email.astro";
import Codepen from "@components/Icons/Codepen.astro";
import Linkedin from "@components/Icons/Linkedin.astro";
import { Content as AboutEn } from "../content/about.md";
import { Content as AboutBn } from "../content/about-bn.md";
import ContactForm from "@components/ContactForm.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<MainLayout title={t('about.title')}>
  <main class="page-workspace">
    <header class="page-header">
      <div class="page-header-inner">
        <span class="page-kicker">/ ABOUT</span>
        <h1 class="page-title" data-decipher="Fazley Rabbi">Fazley Rabbi</h1>
        <p class="page-sub">{t('about.tagline')}</p>
      </div>
    </header>

    <div class="about-card">
      <article class="prose prose-neutral dark:prose-invert max-w-none">
        {lang === 'bn' ? <AboutBn /> : <AboutEn />}
      </article>
    </div>

    <section id="contact" class="contact-section">
      <div class="contact-head">
        <span class="page-kicker">/ {t('about.contact.label')}</span>
        <h2 class="contact-title">{t('about.contact.title')}</h2>
        <p class="contact-sub">{t('about.contact.subtitle')}</p>
      </div>
      <div class="contact-card">
        <ContactForm />
      </div>
    </section>

    <div class="social-row">
      <span class="social-label">{t('about.social')}</span>
      <div class="social-icons">
        <a href="https://github.com/fazleyrabby" target="_blank" aria-label="GitHub"><Github /></a>
        <a href="https://linkedin.com/in/fazley-rabby" target="_blank" aria-label="LinkedIn"><Linkedin /></a>
        <a href="https://youtube.com/@fazleyrabby" target="_blank" aria-label="YouTube"><Youtube /></a>
        <a href="mailto:fazley111@gmail.com" aria-label="Email"><Email /></a>
        <a href="https://codepen.io/fazleyrabby" target="_blank" aria-label="Codepen"><Codepen /></a>
      </div>
    </div>
  </main>
</MainLayout>

<style>
  .page-workspace { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; }

  .page-header {
    padding: 16px 0 12px;
    border-bottom: 1px solid var(--grid-line-strong);
  }
  .page-header-inner { display: flex; flex-direction: column; gap: 2px; }
  .page-kicker {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--accent);
  }
  .page-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    line-height: 1.05;
    color: var(--text-primary);
    margin: 0;
  }
  .page-sub {
    font-family: var(--font-serif, var(--font-sans));
    font-style: italic;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 2px 0 0;
  }

  .about-card {
    background: color-mix(in srgb, var(--text-primary) 4%, var(--bg-base));
    border: 1px solid var(--grid-line-strong);
    padding: 20px 28px;
    margin-top: 16px;
  }
  .about-card :global(.prose) {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .about-card :global(.prose p) { margin: 6px 0; line-height: 1.6; }
  .about-card :global(.prose h2) {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 18px 0 8px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--grid-line-strong);
  }
  .about-card :global(.prose h2:first-child) { margin-top: 0; }
  .about-card :global(.prose h3) {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 10px 0 4px;
  }
  .about-card :global(.prose ul) { margin: 6px 0; padding-left: 18px; }
  .about-card :global(.prose li) { margin: 2px 0; line-height: 1.55; }
  .about-card :global(.prose strong) { color: var(--text-primary); font-weight: 600; }

  .contact-section {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--grid-line-strong);
  }
  .contact-head { display: flex; flex-direction: column; gap: 2px; margin-bottom: 12px; }
  .contact-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
    color: var(--text-primary);
    margin: 0;
  }
  .contact-sub {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 2px 0 0;
  }
  .contact-card {
    background: color-mix(in srgb, var(--text-primary) 4%, var(--bg-base));
    border: 1px solid var(--grid-line-strong);
    padding: 16px 20px;
  }

  .social-row {
    margin-top: 16px;
    padding: 16px 0;
    border-top: 1px solid var(--grid-line-strong);
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }
  .social-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .social-icons {
    display: flex;
    gap: 18px;
  }
  .social-icons a {
    color: var(--text-secondary);
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .social-icons a:hover { color: var(--accent); transform: translateY(-2px); }
</style>
