---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Posts">
  <div class="max-w-6xl mx-auto px-8 py-10">
    <div class="flex items-center justify-between mb-12 !bg-transparent !border-none !shadow-none !p-0 !sticky-none !backdrop-filter-none">
      <div class="flex items-center gap-4">
        <h1 class="text-xl font-bold tracking-tight text-adm-text">Posts</h1>
        <div class="h-4 w-[1px] bg-adm-border"></div>
        <span id="tokenStatus" class="text-[10px] text-adm-muted font-mono uppercase tracking-widest leading-none">Database Active</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="/admin/media" class="text-xs text-adm-muted hover:text-adm-text transition-colors uppercase tracking-wider font-bold">Media</a>
        <button id="themeToggle" class="text-adm-muted hover:text-adm-text transition-colors p-1" title="Toggle Theme">
          <svg id="sunIcon" class="hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M22 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
          <svg id="moonIcon" class="block dark:hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button id="logoutBtn" class="text-xs text-adm-muted hover:text-adm-text transition-colors uppercase tracking-wider font-bold">Logout</button>
      </div>
    </div>

    <div class="flex items-center gap-3 mb-8">
      <div class="relative flex-1">
        <input 
          type="text" 
          id="search" 
          placeholder="Search posts..." 
          class="w-full bg-adm-panel border border-adm-border rounded-md px-3 py-1.5 text-sm text-adm-text focus:outline-none focus:border-adm-primary/50 transition-colors placeholder:text-adm-muted/50"
        />
      </div>
      <a href="/admin/create" class="bg-adm-primary hover:opacity-90 text-white px-4 py-1.5 rounded-md text-sm font-medium transition-all">
        New Post
      </a>
    </div>

    <div id="postList" class="space-y-1">
      <div class="text-center py-20 text-adm-muted animate-pulse text-sm">Loading posts...</div>
    </div>

    <footer class="mt-12 pt-6 border-t border-adm-border flex justify-between items-center text-[10px] text-muted uppercase tracking-widest font-mono">
      <span id="postCount">0 posts</span>
      <span>GitHub Sync Active</span>
    </footer>
  </div>
</AdminLayout>

<script>
  const API = import.meta.env.PUBLIC_API_URL || (window.location.hostname === 'localhost' ? 'http://localhost:3005' : 'https://cms.fazleyrabbi.xyz');
  let allPosts = [];

  function getToken() {
    const t = localStorage.getItem('cms_token');
    if (!t) { window.location.href = '/admin/login?r=/admin'; return null; }
    return t;
  }

  function authHeaders() {
    return { 'Authorization': `Bearer ${getToken()}`, 'Content-Type': 'application/json' };
  }

  function render(posts) {
    const el = document.getElementById('postList');
    const countEl = document.getElementById('postCount');
    
    if (!posts.length) {
      el.innerHTML = '<div class="text-center py-20 text-adm-muted text-sm border border-dashed border-adm-border rounded-lg">No posts found.</div>';
      countEl.textContent = '0 posts';
      return;
    }

    // Desktop table
    const tableRows = posts.map(p => {
      let displayTitle = p.title;
      if (!displayTitle || displayTitle.trim() === '' || displayTitle.toLowerCase() === 'untitled' || displayTitle === 'undefined') {
        displayTitle = p.slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
      }
      const isDraft = p.status === 'draft' || p.draft;
      const statusLabel = p.status || (isDraft ? 'draft' : 'published');
      const date = (p.published_at || p.updated_at) ? new Date(p.published_at || p.updated_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '—';
      return { p, displayTitle, isDraft, statusLabel, date };
    });

    el.innerHTML = `
      <div class="hidden md:block">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-adm-border text-[10px] uppercase tracking-widest text-adm-muted font-mono">
              <th class="text-left pb-2 font-medium">Title</th>
              <th class="text-left pb-2 font-medium">Slug</th>
              <th class="text-left pb-2 font-medium">Status</th>
              <th class="text-left pb-2 font-medium">Date</th>
              <th class="text-left pb-2 font-medium">Actions</th>
            </tr>
          </thead>
          <tbody>
            ${tableRows.map(({ p, displayTitle, isDraft, statusLabel, date }) => `
              <tr class="group border-b border-adm-border/40 hover:bg-adm-panel transition-colors">
                <td class="py-3 pr-4">
                  <a href="/admin/edit?slug=${p.slug}" class="font-medium text-adm-text group-hover:text-adm-primary transition-colors">${displayTitle}</a>
                </td>
                <td class="py-3 pr-4 font-mono text-[11px] text-adm-muted max-w-[160px]"><span class="block truncate" title="${p.slug}">${p.slug}</span></td>
                <td class="py-3 pr-4">
                  <span class="text-[10px] uppercase tracking-widest font-bold ${isDraft ? 'text-amber-500' : 'text-emerald-500'}">${statusLabel}</span>
                </td>
                <td class="py-3 pr-4 font-mono text-[11px] text-adm-muted">${date}</td>
                <td class="py-3">
                  <button onclick="window.deletePost('${p.slug}')" class="text-[10px] uppercase tracking-widest font-bold text-red-500/60 hover:text-red-500 transition-colors">Delete</button>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
      <div class="md:hidden space-y-2">
        ${tableRows.map(({ p, displayTitle, isDraft, statusLabel, date }) => `
          <div class="border border-adm-border rounded-lg p-3 bg-adm-panel">
            <div class="flex items-start justify-between gap-2 mb-1.5">
              <a href="/admin/edit?slug=${p.slug}" class="font-medium text-adm-text text-sm leading-snug flex-1">${displayTitle}</a>
              <span class="text-[10px] uppercase tracking-widest font-bold shrink-0 ${isDraft ? 'text-amber-500' : 'text-emerald-500'}">${statusLabel}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="font-mono text-[10px] text-adm-muted/60">${date}</span>
              <button onclick="window.deletePost('${p.slug}')" class="text-[10px] uppercase tracking-widest font-bold text-red-500/60 hover:text-red-500 transition-colors">Delete</button>
            </div>
          </div>
        `).join('')}
      </div>
    `;
    
    countEl.textContent = `${posts.length} posts`;
  }

  async function loadPosts() {
    try {
      const res = await fetch(`${API}/cms/posts`, { headers: authHeaders() });
      if (res.status === 401) { 
        localStorage.removeItem('cms_token'); 
        window.location.href = '/admin/login'; 
        return; 
      }
      if (!res.ok) throw new Error('Failed to fetch posts');
      allPosts = await res.json();
      render(allPosts);
    } catch (e) {
      document.getElementById('postList').innerHTML = `<div class="text-center py-20 text-red-400 text-sm">Error: ${e.message}</div>`;
    }
  }

  // @ts-ignore
  window.deletePost = async function(slug) {
    if (!confirm(`Permanently delete "${slug}"?`)) return;
    
    try {
      const res = await fetch(`${API}/cms/posts/${slug}`, { 
        method: 'DELETE', 
        headers: authHeaders() 
      });
      if (!res.ok) throw new Error('Delete failed');
      
      allPosts = allPosts.filter(p => p.slug !== slug);
      render(allPosts);
    } catch (e) {
      alert(`Delete failed: ${e.message}`);
    }
  };

  document.getElementById('search').addEventListener('input', (e) => {
    // @ts-ignore
    const q = e.target.value.toLowerCase();
    render(q ? allPosts.filter(p => p.slug.toLowerCase().includes(q) || p.title.toLowerCase().includes(q)) : allPosts);
  });

  document.getElementById('logoutBtn').addEventListener('click', () => {
    localStorage.removeItem('cms_token');
    window.location.href = '/admin/login';
  });

  // Theme Toggle Logic
  const themeToggle = document.getElementById('themeToggle');
  themeToggle.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('adm_theme', 'light');
    } else {
      document.documentElement.classList.add('dark');
      localStorage.setItem('adm_theme', 'dark');
    }
  });

  const token = getToken();
  if (token) {
    loadPosts();
  }
</script>
