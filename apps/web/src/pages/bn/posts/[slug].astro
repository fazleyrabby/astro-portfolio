---
import Page from '../../posts/[slug].astro';
import { supabase } from '../../../lib/supabase';

export async function getStaticPaths() {
  const { data: posts } = await supabase
    .from('posts')
    .select('slug')
    .eq('status', 'published');
  
  return (posts || []).map((post) => ({
    params: { slug: post.slug },
  }));
}
---
<Page {...Astro.props} />
