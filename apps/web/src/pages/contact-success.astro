---
import MainLayout from "@layouts/MainLayout.astro";
---

<MainLayout title="Message Sent — Fazley Rabbi">
  <main class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center px-6">
      <span class="section-label">Contact</span>
      <h1 class="font-display font-bold text-[clamp(2rem,5vw,3rem)] text-[var(--text-primary)] leading-tight mb-4">
        Message received.
      </h1>
      <p class="text-[var(--text-secondary)] mb-8 max-w-md mx-auto">
        Thanks for reaching out — I'll get back to you as soon as possible.
      </p>
      <a href="/" class="btn-ghost">Back to home</a>
    </div>
  </main>
</MainLayout>
