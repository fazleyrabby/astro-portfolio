---
// src/pages/posts/[slug].astro
import MainLayout from "@layouts/MainLayout.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { supabase } from "@lib/supabase";
import { marked } from "marked";

const renderer = new marked.Renderer();
renderer.heading = function({ text, depth }) {
  const id = text.toLowerCase().replace(/[^\w]+/g, '-');
  return `<h${depth} id="${id}">${text}</h${depth}>`;
};
marked.use({ renderer });

export async function getStaticPaths() {
  const { data: posts } = await supabase
    .from('posts')
    .select('slug')
    .eq('status', 'published');
  
  return (posts || []).map((post) => ({
    params: { slug: post.slug },
  }));
}

const rawSlug = Astro.params.slug;
console.log("[DEBUG slug.astro] rawSlug:", rawSlug, "pathname:", Astro.url.pathname);
const slug = rawSlug ? decodeURIComponent(rawSlug) : '';
const currentLang = Astro.url.pathname.startsWith('/bn/') ? 'bn' : 'en';

// Fetch single post data for this specific slug & language
let { data: post, error } = await supabase
  .from('posts')
  .select('*')
  .eq('slug', slug)
  .eq('lang', currentLang)
  .maybeSingle();

// Fallback to EN if BN version is not found
if (!post && currentLang === 'bn') {
  const fallback = await supabase
    .from('posts')
    .select('*')
    .eq('slug', slug)
    .eq('lang', 'en')
    .maybeSingle();
    
  if (fallback.data) {
    post = fallback.data;
    error = null;
  }
}

if (!post) {
  return Astro.redirect('/404');
}

const seoDescription = post.description || post.title;
const articleContent = await marked.parse(post.content);

// Resolve alternate URL for LangToggle
let altUrl = undefined;

if (currentLang === 'en') {
  const { data: altPost } = await supabase
    .from('posts')
    .select('slug')
    .eq('translation_of', post.id)
    .single();
  if (altPost) {
    altUrl = `/bn/posts/${altPost.slug}`;
  }
} else {
  if (post.lang === 'bn' && post.translation_of) {
    const { data: altPost } = await supabase
      .from('posts')
      .select('slug')
      .eq('id', post.translation_of)
      .single();
    if (altPost) {
      altUrl = `/posts/${altPost.slug}`;
    }
  }
}

// Estimate reading time
const wordCount = post.content.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Prepare JSON-LD structured data
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": seoDescription,
  "image": post.cover_image || undefined,
  "datePublished": post.published_at || undefined,
  "dateModified": post.updated_at || post.published_at || undefined,
  "author": {
    "@type": "Person",
    "name": "Fazley Rabbi",
    "url": "https://fazleyrabbi.xyz"
  },
  "publisher": {
    "@type": "Person",
    "name": "Fazley Rabbi",
    "url": "https://fazleyrabbi.xyz"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://fazleyrabbi.xyz/posts/${post.slug}`
  },
  "wordCount": wordCount,
  "keywords": post.tags?.join(", ") || undefined
});
---

<MainLayout 
  title={`${post.title} — Fazley Rabbi`}
  description={seoDescription}
  ogTitle={post.title}
  ogDescription={seoDescription}
  ogImage={post.cover_image}
  ogUrl={`https://fazleyrabbi.xyz/posts/${post.slug}`}
  ogType="article"
  twitterCard="summary_large_image"
  twitterImage={post.cover_image}
  articlePublishedTime={post.published_at || undefined}
  articleModifiedTime={post.updated_at || post.published_at || undefined}
  articleAuthor="Fazley Rabbi"
  articleTags={post.tags || []}
  altUrl={altUrl}
>
  <main class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-12">
      {post.cover_image && (
        <div class="relative w-full rounded-[1.5rem] mb-8 overflow-hidden flex justify-center items-center" data-thumb-container>
          <img 
            data-thumb 
            src={post.cover_image} 
            alt={post.title} 
            width={1200}
            height={630}
            class="max-h-[400px] w-auto max-w-full object-contain" 
            style="-webkit-mask-image: linear-gradient(to right, transparent, black 60px, black calc(100% - 60px), transparent); mask-image: linear-gradient(to right, transparent, black 60px, black calc(100% - 60px), transparent);"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      )}
      <h1 class="font-display font-bold text-[clamp(1.6rem,4vw,2.5rem)] text-[var(--text-primary)] mb-4">{post.title}</h1>
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 flex-wrap mb-4">
        <p class="mb-0">
          <small class="font-mono text-xs text-[var(--text-muted)] uppercase tracking-widest"
            >{
              post.published_at ? new Date(post.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : ""
            }</small
          >
        </p>

        <span class="hidden sm:inline-block text-[var(--border-color)]">|</span>
        <p class="mb-0">
          <small class="font-mono text-xs text-[var(--text-muted)] uppercase tracking-widest">{readingTime} min read</small>
        </p>
        
        {post.tags && post.tags.length > 0 && (
          <>
            <span class="hidden sm:inline-block text-[var(--border-color)]">|</span>
            <div class="flex items-center gap-2 flex-wrap">
              {post.tags.map((tag) => (
                <span class="px-2.5 py-1 text-[10px] font-mono tracking-widest uppercase rounded-full bg-[var(--surface-color)] border border-[var(--border-color)] text-[var(--text-secondary)]">
                  {tag}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
    </div>

    <article id="article-content" class="prose prose-neutral dark:prose-invert max-w-none prose-p:text-[var(--text-secondary)] prose-p:leading-relaxed prose-li:text-[var(--text-secondary)] prose-headings:font-display prose-headings:font-bold prose-headings:text-[var(--text-primary)] prose-strong:text-[var(--text-primary)] prose-strong:font-semibold prose-blockquote:text-[var(--text-secondary)] prose-blockquote:border-[var(--accent)]">
      <Fragment set:html={articleContent} />
    </article>
  </main>

  <TableOfContents />

  <!-- Floating Share Sidebar -->
  <div id="share-sidebar" class="share-sidebar"
    data-url={`https://fazleyrabbi.xyz/posts/${post.slug}`}
    data-title={post.title}
    data-description={seoDescription}
  >
    <span class="share-sidebar-label">Share</span>
    
    <a id="share-x" href="#" target="_blank" rel="noopener noreferrer"
      class="share-sidebar-btn" aria-label="Share on X" title="Share on X">
      <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>

    <a id="share-fb" href="#" target="_blank" rel="noopener noreferrer"
      class="share-sidebar-btn" aria-label="Share on Facebook" title="Share on Facebook">
      <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="currentColor">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
    </a>

    <a id="share-ln" href="#" target="_blank" rel="noopener noreferrer"
      class="share-sidebar-btn" aria-label="Share on LinkedIn" title="Share on LinkedIn">
      <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>

    <div class="share-sidebar-divider"></div>

    <button id="share-copy" class="share-sidebar-btn" aria-label="Copy link" title="Copy link">
      <svg class="w-[18px] h-[18px] share-copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
      </svg>
      <svg class="w-[18px] h-[18px] share-check-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
    </button>
  </div>

  <script type="application/ld+json" set:html={jsonLd} />
</MainLayout>

<style>
  #article-content pre { margin: 0; border-radius: 0; border: none; }
  #article-content .code-block-wrapper { position: relative; }
  #article-content pre code { display: block; }

  /* Floating Share Sidebar */
  .share-sidebar {
    position: fixed;
    left: max(1rem, calc((100vw - 72rem) / 2 - 4rem));
    top: 50%;
    transform: translateY(-50%) translateX(-20px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    z-index: 40;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .share-sidebar.visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(-50%) translateX(0);
  }

  .share-sidebar-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
  }

  .share-sidebar-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .share-sidebar-btn:hover {
    color: var(--accent);
    border-color: var(--border-hover);
    box-shadow: var(--accent-glow);
    transform: scale(1.1);
  }
  .share-sidebar-btn:active {
    transform: scale(0.95);
  }
  .share-sidebar-btn.copied {
    color: #22c55e;
    border-color: #22c55e;
  }

  .share-sidebar-divider {
    width: 20px;
    height: 1px;
    background: var(--border);
    margin: 0.25rem 0;
  }

  /* Mobile: bottom bar */
  @media (max-width: 1279px) {
    .share-sidebar {
      left: 50%;
      top: auto;
      bottom: 1.5rem;
      transform: translateX(-50%) translateY(20px);
      flex-direction: row;
      gap: 0.5rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.5rem 0.75rem;
      box-shadow: 0 8px 32px rgba(0,0,0,0.25);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .share-sidebar.visible {
      transform: translateX(-50%) translateY(0);
    }
    .share-sidebar-label {
      display: none;
    }
    .share-sidebar-divider {
      width: 1px;
      height: 20px;
      margin: 0 0.15rem;
    }
    .share-sidebar-btn {
      width: 36px;
      height: 36px;
      border: none;
      background: transparent;
    }
    .share-sidebar-btn:hover {
      box-shadow: none;
      background: var(--accent-dim);
    }
  }
</style>

<script>
  // Copy button functionality for code blocks
  document.querySelectorAll('pre').forEach(pre => {
    const code = pre.querySelector('code');
    if (!code) return;
    
    const langClass = Array.from(code.classList).find(c => c.startsWith('language-'));
    const lang = langClass ? langClass.replace('language-', '') : 'text';
    const displayLang = lang.toUpperCase();
    
    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper group relative my-6 rounded-lg border border-[var(--border)] bg-[var(--bg-card)] overflow-hidden';
    
    const header = document.createElement('div');
    header.className = 'code-header flex items-center justify-between px-4 py-2 bg-[var(--bg-elevated)] border-b border-[var(--border)]';
    header.innerHTML = `
      <div class="flex items-center gap-2">
        <span class="text-[0.65rem] font-mono font-semibold px-2 py-0.5 rounded bg-[var(--accent)]/10 text-[var(--accent)]">${displayLang}</span>
      </div>
      <button class="copy-btn text-[0.65rem] font-mono px-2 py-0.5 rounded bg-[var(--bg-elevated)] border border-[var(--border)] text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:border-[var(--accent)] transition-all opacity-0 group-hover:opacity-100">Copy</button>
    `;
    
    pre.parentNode.insertBefore(wrapper, pre);
    wrapper.appendChild(header);
    wrapper.appendChild(pre);
    pre.className = '!mt-0 !rounded-none !border-0 overflow-x-auto p-4 text-sm leading-relaxed';
    
    const btn = header.querySelector('.copy-btn');
    btn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(code.textContent || '');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    });
  });
</script>

<script>
  // Share sidebar functionality
  const sidebar = document.getElementById('share-sidebar');
  if (sidebar) {
    const url = encodeURIComponent(sidebar.dataset.url || window.location.href);
    const title = encodeURIComponent(sidebar.dataset.title || document.title);

    const xBtn = document.getElementById('share-x') as HTMLAnchorElement;
    if (xBtn) xBtn.href = `https://x.com/intent/tweet?text=${title}&url=${url}`;

    const fbBtn = document.getElementById('share-fb') as HTMLAnchorElement;
    if (fbBtn) fbBtn.href = `https://www.facebook.com/sharer/sharer.php?u=${url}`;

    const lnBtn = document.getElementById('share-ln') as HTMLAnchorElement;
    if (lnBtn) lnBtn.href = `https://www.linkedin.com/sharing/share-offsite/?url=${url}`;

    const copyBtn = document.getElementById('share-copy');
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const rawUrl = sidebar.dataset.url || window.location.href;
        await navigator.clipboard.writeText(rawUrl);
        const linkIcon = copyBtn.querySelector('.share-copy-icon') as HTMLElement;
        const checkIcon = copyBtn.querySelector('.share-check-icon') as HTMLElement;
        copyBtn.classList.add('copied');
        if (linkIcon) linkIcon.classList.add('hidden');
        if (checkIcon) checkIcon.classList.remove('hidden');
        setTimeout(() => {
          copyBtn.classList.remove('copied');
          if (linkIcon) linkIcon.classList.remove('hidden');
          if (checkIcon) checkIcon.classList.add('hidden');
        }, 2000);
      });
    }

    // Show/hide sidebar based on article scroll position
    const article = document.getElementById('article-content');
    if (article) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            sidebar.classList.add('visible');
          } else {
            sidebar.classList.remove('visible');
          }
        });
      }, { threshold: 0, rootMargin: '-100px 0px -100px 0px' });
      observer.observe(article);
    }
  }
</script>

<script is:inline define:vars={{ apiUrl: import.meta.env.PUBLIC_API_URL || 'https://cms.fazleyrabbi.xyz' }}>
  const img = document.querySelector('img[data-thumb]');
  if (img) {
    const cacheKey = `thumb-bg:${img.src}`;
    const cached = sessionStorage.getItem(cacheKey);

    const applyColor = (color) => {
      const container = document.querySelector('[data-thumb-container]');
      if (container) {
        container.style.backgroundColor = color;
        container.style.setProperty('--edge-color', color);
      }
    };

    if (cached) {
      applyColor(cached);
    } else {
      const detectBg = () => {
        const proxy = new Image();
        proxy.crossOrigin = 'anonymous';
        proxy.src = `${apiUrl}/image-proxy?url=${encodeURIComponent(img.src)}`;
        proxy.onload = () => {
          try {
            const c = document.createElement('canvas');
            const ctx = c.getContext('2d');
            if (!ctx) return;
            const w = proxy.naturalWidth;
            const h = proxy.naturalHeight;
            c.width = w;
            c.height = h;
            ctx.drawImage(proxy, 0, 0);

            let r = 0, g = 0, b = 0, count = 0;
            const sample = (x: number, y: number) => {
              const d = ctx.getImageData(x, y, 1, 1).data;
              r += d[0]; g += d[1]; b += d[2]; count++;
            };
            const step = Math.max(1, Math.floor(Math.max(w, h) / 20));
            for (let x = 0; x < w; x += step) { sample(x, 0); sample(x, h - 1); }
            for (let y = 0; y < h; y += step) { sample(0, y); sample(w - 1, y); }

            const color = `rgb(${Math.round(r / count)}, ${Math.round(g / count)}, ${Math.round(b / count)})`;
            applyColor(color);
            sessionStorage.setItem(cacheKey, color);
          } catch {
            applyColor('#000');
          }
        };
        proxy.onerror = () => { applyColor('#000'); };
      };
      if (img.complete) detectBg();
      else img.addEventListener('load', detectBg);
    }
  }
</script>
