---
// src/pages/posts/[slug].astro
export const prerender = false;

import MainLayout from "@layouts/MainLayout.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { supabase } from "@lib/supabase";
import { marked } from "marked";

const { slug } = Astro.params;

// Fetch strictly from Supabase
const { data: post, error } = await supabase
  .from('posts')
  .select('*')
  .eq('slug', slug)
  .single();

if (error || !post) {
  return Astro.redirect('/404');
}

// Simple SEO description fallback
const seoDescription = post.description || post.title;
---

<MainLayout 
  title={post.title}
  ogTitle={post.title}
  ogDescription={seoDescription}
  ogImage={post.cover_image}
  ogUrl={`https://fazleyrabbi.xyz/posts/${post.slug}`}
  ogType="article"
  twitterCard="summary_large_image"
  twitterImage={post.cover_image}
>
  <main class="max-w-6xl mx-auto px-6 py-16">
    <!-- Hero: thumbnail + title -->
    <div class="max-w-3xl mx-auto lg:mx-0 lg:max-w-none mb-12">
      {post.cover_image && (
        <div class="relative w-full rounded-[1.5rem] mb-8 overflow-hidden flex justify-center items-center" data-thumb-container>
          <img 
            data-thumb 
            src={post.cover_image} 
            alt={post.title} 
            class="max-h-[400px] w-auto max-w-full object-contain" 
            style="-webkit-mask-image: linear-gradient(to right, transparent, black 60px, black calc(100% - 60px), transparent); mask-image: linear-gradient(to right, transparent, black 60px, black calc(100% - 60px), transparent);"
            loading="lazy" 
          />
        </div>
      )}
      <h1 class="font-display font-bold text-[clamp(2rem,5vw,3.5rem)] text-[var(--text-primary)] mb-4">{post.title}</h1>
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 flex-wrap mb-4">
        <p class="mb-0">
          <small class="font-mono text-xs text-[var(--text-muted)] uppercase tracking-widest"
            >{
              post.published_at ? new Date(post.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : ""
            }</small
          >
        </p>
        
        {post.tags && post.tags.length > 0 && (
          <>
            <span class="hidden sm:inline-block text-[var(--border-color)]">|</span>
            <div class="flex items-center gap-2 flex-wrap">
              {post.tags.map((tag) => (
                <span class="px-2.5 py-1 text-[10px] font-mono tracking-widest uppercase rounded-full bg-[var(--surface-color)] border border-[var(--border-color)] text-[var(--text-secondary)]">
                  {tag}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
    </div>

    <!-- Content grid: article + TOC sidebar -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
      <article id="article-content" class="lg:col-span-8 prose prose-neutral dark:prose-invert max-w-none prose-p:text-[var(--text-secondary)] prose-p:leading-relaxed prose-li:text-[var(--text-secondary)] prose-headings:font-display prose-headings:font-bold prose-headings:text-[var(--text-primary)] prose-strong:text-[var(--text-primary)] prose-strong:font-semibold prose-blockquote:text-[var(--text-secondary)] prose-blockquote:border-[var(--accent)]">
        <Fragment set:html={marked.parse(post.content)} />
      </article>
      <TableOfContents />
    </div>
  </main>
</MainLayout>

<script>
  const img = document.querySelector('img[data-thumb]') as HTMLImageElement | null;
  if (img) {
    const cacheKey = `thumb-bg:${img.src}`;
    const cached = sessionStorage.getItem(cacheKey);

    const applyColor = (color: string) => {
      const container = document.querySelector('[data-thumb-container]') as HTMLElement | null;
      if (container) {
        container.style.backgroundColor = color;
        container.style.setProperty('--edge-color', color);
      }
    };

    if (cached) {
      applyColor(cached);
    } else {
      const detectBg = () => {
        const proxy = new Image();
        proxy.crossOrigin = 'anonymous';
        proxy.src = `https://api.fazleyrabbi.xyz/image-proxy?url=${encodeURIComponent(img.src)}`;        proxy.onload = () => {
          try {
            const c = document.createElement('canvas');
            const ctx = c.getContext('2d');
            if (!ctx) return;
            const w = proxy.naturalWidth;
            const h = proxy.naturalHeight;
            c.width = w;
            c.height = h;
            ctx.drawImage(proxy, 0, 0);

            let r = 0, g = 0, b = 0, count = 0;
            const sample = (x: number, y: number) => {
              const d = ctx.getImageData(x, y, 1, 1).data;
              r += d[0]; g += d[1]; b += d[2]; count++;
            };
            const step = Math.max(1, Math.floor(Math.max(w, h) / 20));
            for (let x = 0; x < w; x += step) { sample(x, 0); sample(x, h - 1); }
            for (let y = 0; y < h; y += step) { sample(0, y); sample(w - 1, y); }

            const color = `rgb(${Math.round(r / count)}, ${Math.round(g / count)}, ${Math.round(b / count)})`;
            applyColor(color);
            sessionStorage.setItem(cacheKey, color);
          } catch {
            applyColor('#000');
          }
        };
        proxy.onerror = () => { applyColor('#000'); };
      };
      if (img.complete) detectBg();
      else img.addEventListener('load', detectBg);
    }
  }
</script>

<script>
  // Wrap code blocks logic (Existing logic remains identical)
  document.querySelectorAll('#article-content pre').forEach((pre) => {
    if (pre.parentElement?.classList.contains('code-block-wrapper')) return;
    const lang = pre.getAttribute('data-language') || '';
    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper';
    const header = document.createElement('div');
    header.className = 'code-block-header';
    const dots = document.createElement('div');
    dots.className = 'code-block-dots';
    dots.innerHTML = '<span class="dot dot-red"></span><span class="dot dot-yellow"></span><span class="dot dot-green"></span>';
    header.appendChild(dots);
    const rightSide = document.createElement('div');
    rightSide.className = 'code-block-right';
    if (lang) {
      const badge = document.createElement('span');
      badge.className = 'code-block-lang';
      badge.textContent = lang.toUpperCase();
      rightSide.appendChild(badge);
    }
    const copyBtn = document.createElement('button');
    copyBtn.className = 'code-block-copy';
    copyBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg><span class="copy-text">Copy</span>`;
    copyBtn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.innerText || pre.innerText;
      await navigator.clipboard.writeText(code);
      copyBtn.querySelector('.copy-text')!.textContent = 'Copied!';
      setTimeout(() => { copyBtn.querySelector('.copy-text')!.textContent = 'Copy'; }, 2000);
    });
    rightSide.appendChild(copyBtn);
    header.appendChild(rightSide);
    pre.parentNode!.insertBefore(wrapper, pre);
    wrapper.appendChild(header);
    wrapper.appendChild(pre);
  });
</script>
