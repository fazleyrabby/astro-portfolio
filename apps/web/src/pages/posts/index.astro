---
import MainLayout from "@layouts/MainLayout.astro";
import { supabase } from "@lib/supabase";

export const prerender = false;

// Fetch strictly from Supabase
const { data: posts, error } = await supabase
  .from('posts')
  .select('*')
  .eq('status', 'published')
  .order('published_at', { ascending: false });

if (error) {
  console.error("Supabase error:", error);
}

const publishedPosts = posts || [];

const featuredPosts = publishedPosts.filter(post => post.featured);
const regularPosts = publishedPosts.filter(post => !post.featured);

// Split featured posts into Hero and Others
const [heroPost, ...otherFeatured] = featuredPosts;
---

<MainLayout title="Posts">
  <section class="max-w-6xl mx-auto px-6 py-8">
    <div class="section-label font-mono animate-in slide-in-from-bottom-2 duration-500">Journal</div>
    <div class="animate-in slide-in-from-bottom-4 duration-700">
      <h1 class="page-heading">Backend Engineering <span class="text-[var(--accent)]">&</span> Insights</h1>
      <p class="text-[var(--text-secondary)] max-w-[600px] mb-12 leading-[1.7] text-lg">
        Deep dives into production Laravel patterns, system architecture, and technical challenges solved in the real world.
      </p>
    </div>

    {featuredPosts.length > 0 && (
      <div class="mb-20 animate-in fade-in zoom-in-95 duration-1000">
        <div class="flex items-center gap-3 mb-8">
          <h2 class="text-xs font-mono text-[var(--accent)] uppercase tracking-[0.2em] font-semibold">Featured Highlights</h2>
          <div class="h-[1px] flex-grow bg-gradient-to-r from-[var(--border)] to-transparent"></div>
        </div>
        
        <div class="space-y-8">
          {/* Main Hero Featured Post */}
          <article class="featured-hero group relative border border-[var(--border)] rounded-sm overflow-hidden bg-[rgba(255,255,255,0.015)] transition-all hover:border-[var(--accent)] hover:shadow-[0_0_50px_rgba(6,182,212,0.08)]">
            <a href={`/posts/${heroPost.slug}`} class="grid lg:grid-cols-12 no-underline items-stretch">
              <div class="lg:col-span-7 p-8 md:p-12 lg:p-16 flex flex-col justify-center">
                <div class="flex items-center gap-3 font-mono text-[0.65rem] text-[var(--text-muted)] mb-6 uppercase tracking-widest">
                  <span class="px-2 py-0.5 rounded-full border border-[var(--accent)] text-[var(--accent)]">Special</span>
                  {heroPost.published_at ? new Date(heroPost.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Unknown'}
                </div>
                <h3 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-[var(--text-primary)] mb-8 leading-[1.1] group-hover:text-[var(--accent)] transition-all duration-300">
                  {heroPost.title}
                </h3>
                <p class="text-[var(--text-secondary)] text-lg mb-10 line-clamp-3 leading-relaxed max-w-[550px]">
                  {heroPost.description || "An in-depth analysis of critical production engineering patterns and scalable architecture."}
                </p>
                <div class="flex items-center gap-4 text-sm font-semibold text-[var(--accent)]">
                  <span class="h-[1px] w-8 bg-[var(--accent)] transition-all duration-300 group-hover:w-12"></span>
                  Start Reading
                </div>
              </div>
              
              <div class="lg:col-span-5 h-[300px] lg:h-auto overflow-hidden bg-[var(--background-secondary)] order-first lg:order-last border-b lg:border-b-0 lg:border-l border-[var(--border)] group-hover:border-[var(--accent)] transition-colors relative">
                {heroPost.cover_image ? (
                  <img src={heroPost.cover_image} alt={heroPost.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-60 group-hover:opacity-90 grayscale-[30%] group-hover:grayscale-0" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center overflow-hidden">
                    <div class="w-[140%] h-[140%] border-[var(--accent)] border-dashed border opacity-[0.03] rotate-45 pointer-events-none"></div>
                    <div class="relative z-10 w-48 h-48 rounded-full border border-[var(--accent)] border-dashed animate-spin-slow opacity-10"></div>
                    <span class="absolute text-8xl font-display font-black opacity-[0.02] italic text-[var(--accent)] -right-10 bottom-0 pointer-events-none">HERO</span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-r from-[rgba(0,0,0,0.4)] to-transparent lg:hidden"></div>
              </div>
            </a>
          </article>

          {/* Secondary Featured Posts Grid */}
          {otherFeatured.length > 0 && (
            <div class="grid md:grid-cols-2 gap-8">
              {otherFeatured.map((post) => (
                <article class="featured-sub-card group relative border border-[var(--border)] rounded-sm overflow-hidden bg-transparent transition-all hover:border-[var(--accent)] hover:shadow-glow">
                  <a href={`/posts/${post.slug}`} class="flex flex-col h-full no-underline p-8">
                    <div class="font-mono text-[0.6rem] text-[var(--text-muted)] mb-4 uppercase tracking-[0.2em] flex items-center gap-3">
                      <span class="inline-block w-1.5 h-1.5 rounded-full bg-[var(--accent)] opacity-50"></span>
                      {post.published_at ? new Date(post.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short' }) : 'Unknown'}
                    </div>
                    <h3 class="font-display font-semibold text-xl text-[var(--text-primary)] mb-6 leading-tight group-hover:text-[var(--accent)] transition-colors">
                      {post.title}
                    </h3>
                    <p class="text-[var(--text-secondary)] text-sm mb-8 line-clamp-2 opacity-80 group-hover:opacity-100 transition-opacity">
                      {post.description || "Exploring advanced system architecture and engineering trade-offs."}
                    </p>
                    <div class="mt-auto flex items-center gap-2 text-xs font-bold text-[var(--accent)] uppercase tracking-widest opacity-0 group-hover:opacity-100 translate-x-[-10px] group-hover:translate-x-0 transition-all duration-300">
                      View Pattern <span class="text-lg">→</span>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          )}
        </div>
      </div>
    )}

    {/* Regular Feed */}
    <div class="animate-in fade-in duration-1000 delay-300">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xs font-mono text-[var(--text-muted)] uppercase tracking-[0.2em]">Latest Archive</h2>
        <div class="h-[1px] flex-grow bg-gradient-to-r from-[var(--border)] to-transparent opacity-40"></div>
      </div>
      
      <div id="posts-grid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {regularPosts.map((post, index) => (
          <article 
            class={`post-card group card border border-[var(--border)] rounded-sm transition-all hover:bg-[rgba(255,255,255,0.01)] h-full ${index >= 6 ? 'hidden' : ''}`}
            data-index={index}
          >
            <a href={`/posts/${post.slug}`} class="flex flex-col p-6 no-underline h-full">
              <div class="font-mono text-[0.72rem] text-[var(--text-muted)] mb-3 flex justify-between items-center">
                <span>{post.published_at ? new Date(post.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Unknown'}</span>
                <span class="opacity-0 group-hover:opacity-100 transition-opacity text-[var(--accent)]">→</span>
              </div>
              <h3 class="font-display font-bold text-lg text-[var(--text-primary)] mb-3 leading-snug group-hover:text-[var(--accent)] transition-colors">
                {post.title}
              </h3>
            </a>
          </article>
        ))}
      </div>

      {regularPosts.length > 6 && (
        <div class="mt-12 flex justify-center">
          <button 
            id="show-more-btn"
            class="px-8 py-3 rounded-full border border-[var(--border)] text-[var(--text-muted)] hover:text-[var(--accent)] hover:border-[var(--accent)] hover:shadow-glow-sm transition-all duration-300 font-mono text-sm uppercase tracking-widest bg-transparent cursor-pointer"
          >
            Read More Archive
          </button>
        </div>
      )}
    </div>

    {publishedPosts.length === 0 && (
      <div class="text-center py-24 border border-dashed border-[var(--border)] rounded-sm">
        <div class="text-4xl mb-6 opacity-30">📚</div>
        <p class="text-[var(--text-muted)] font-mono text-sm">Synchronizing brain dump... no articles found yet.</p>
      </div>
    )}
  </section>
</MainLayout>

<script>
  const showMoreBtn = document.getElementById('show-more-btn');
  const postsGrid = document.getElementById('posts-grid');
  
  if (showMoreBtn && postsGrid) {
    showMoreBtn.addEventListener('click', () => {
      const hiddenPosts = postsGrid.querySelectorAll('.hidden');
      hiddenPosts.forEach(post => {
        post.classList.remove('hidden');
        post.classList.add('animate-in', 'fade-in', 'slide-in-from-bottom-4', 'duration-500');
      });
      showMoreBtn.remove();
    });
  }
</script>

<style>
  .animate-spin-slow {
    animation: spin 30s linear infinite;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .featured-hero {
    position: relative;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
  }
  .featured-hero:hover {
    box-shadow: 0 0 50px rgba(6, 182, 212, 0.08);
  }
  .featured-sub-card:hover {
    background: linear-gradient(145deg, rgba(255,255,255,0.02) 0%, transparent 100%);
  }
  .animate-in {
    animation-fill-mode: both;
  }
</style>
