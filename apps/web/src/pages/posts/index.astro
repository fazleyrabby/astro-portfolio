---
import MainLayout from "@layouts/MainLayout.astro";
import { supabase } from "@lib/supabase";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { data: allPosts, error } = await supabase
  .from('posts')
  .select('*')
  .eq('status', 'published')
  .in('lang', ['en', lang])
  .order('published_at', { ascending: false });

if (error) console.error("Supabase error:", error);

let publishedPosts: any[] = [];
if (allPosts) {
  if (lang === 'bn') {
    const bnPosts = allPosts.filter(p => p.lang === 'bn');
    const translatedEnIds = new Set(bnPosts.map(p => p.translation_of).filter(Boolean));
    publishedPosts = allPosts.filter(p => {
      if (p.lang === 'bn') return true;
      if (p.lang === 'en' && !translatedEnIds.has(p.id)) return true;
      return false;
    });
  } else {
    publishedPosts = allPosts.filter(p => p.lang === 'en');
  }
}

function extractFirstImage(content: string) {
  if (!content) return null;
  const match = content.match(/!\[.*?\]\((.*?)\)/);
  return match ? match[1] : null;
}

const cleanTag = (tag: any) => {
  if (typeof tag === 'string') return tag.replace(/^["']|["']$/g, '').trim();
  return String(tag);
};

const postsWithImages = publishedPosts.map((post: any) => ({
  ...post,
  cover_image: post.cover_image || extractFirstImage(post.content),
  tags: [...new Set((post.tags || []).map(cleanTag))]
}));

const featuredPosts = postsWithImages.filter((p: any) => p.featured);
const regularPosts = postsWithImages.filter((p: any) => !p.featured);
const [heroPost, ...otherFeatured] = featuredPosts;
const allTags = [...new Set(postsWithImages.flatMap((post: any) => post.tags || []))].sort();

const gridCols = 3;
const fillerCount = (gridCols - (regularPosts.length % gridCols)) % gridCols;
const fillers = Array.from({ length: fillerCount });
---

<MainLayout title={t('posts.journal')}>
  <main class="page-workspace">
    <header class="page-header">
      <div class="page-header-inner">
        <span class="page-kicker">/ NOTES</span>
        <h1 class="page-title" set:html={t('posts.index.title')}></h1>
        <p class="page-sub">{t('posts.index.subtitle')}</p>
      </div>

      <div class="page-controls">
        <div class="control-input">
          <input type="text" id="search-input" placeholder="Search articles…" />
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <select id="tag-select" class="control-select">
          <option value="all">All Tags</option>
          {allTags.map(tag => <option value={tag}>{tag}</option>)}
        </select>
      </div>
    </header>

    {featuredPosts.length > 0 && (
      <section class="grid-section">
        <div class="grid-section-head">
          <span>FEATURED</span>
          <span class="counter">{String(featuredPosts.length).padStart(2, '0')}</span>
        </div>

        <div class="featured-grid">
          {heroPost && (
            <article class="post-card post-card--hero" data-tags={JSON.stringify(heroPost.tags || [])} data-title={heroPost.title || heroPost.slug}>
              <a href={translatePath(`/posts/${heroPost.slug}`)} class="post-card-link">
                {heroPost.cover_image && (
                  <div class="post-thumb post-thumb--hero">
                    <img src={heroPost.cover_image} alt={heroPost.title} loading="lazy" />
                  </div>
                )}
                <div class="post-body">
                  <div class="post-meta">
                    <span class="post-badge">FEATURED</span>
                    <span>{heroPost.published_at ? new Date(heroPost.published_at).toLocaleDateString(lang === 'bn' ? 'bn-BD' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Draft'}</span>
                  </div>
                  <h3 class="post-title post-title--hero">{heroPost.title || heroPost.slug}</h3>
                  <p class="post-desc">{heroPost.description}</p>
                  <div class="post-tags">
                    {heroPost.tags && heroPost.tags.slice(0,4).map((tag: string) => <span class="tg">{tag}</span>)}
                  </div>
                </div>
              </a>
            </article>
          )}

          {otherFeatured.slice(0, 2).map((post: any) => (
            <article class="post-card post-card--sub" data-tags={JSON.stringify(post.tags || [])} data-title={post.title || post.slug}>
              <a href={translatePath(`/posts/${post.slug}`)} class="post-card-link post-card-link--row">
                {post.cover_image && (
                  <div class="post-thumb post-thumb--sub">
                    <img src={post.cover_image} alt={post.title} loading="lazy" />
                  </div>
                )}
                <div class="post-body">
                  <div class="post-meta">
                    <span>{post.published_at ? new Date(post.published_at).toLocaleDateString(lang === 'bn' ? 'bn-BD' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Draft'}</span>
                  </div>
                  <h3 class="post-title">{post.title || post.slug}</h3>
                  <p class="post-desc post-desc--sm">{post.description}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="grid-section">
      <div class="grid-section-head">
        <span class="archive-header">ALL ARTICLES</span>
        <span class="counter">{String(regularPosts.length).padStart(2, '0')}</span>
      </div>

      <div class="posts-grid" id="posts-grid">
        {regularPosts.map((post: any) => (
          <article class="post-card post-card--cell" data-tags={JSON.stringify(post.tags || [])} data-title={post.title || post.slug}>
            <a href={translatePath(`/posts/${post.slug}`)} class="post-card-link">
              <div class="post-body">
                <h3 class="post-title">{post.title || post.slug}</h3>
                {post.description && <p class="post-desc post-desc--sm">{post.description}</p>}
                {post.tags && post.tags.length > 0 && (
                  <div class="post-tags">
                    {post.tags.slice(0,3).map((tag: string) => <span class="tg">{tag}</span>)}
                  </div>
                )}
              </div>
              <div class="post-foot">
                <span>{post.published_at ? new Date(post.published_at).toLocaleDateString(lang === 'bn' ? 'bn-BD' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Draft'}</span>
                <span class="post-foot-arrow">→</span>
              </div>
            </a>
          </article>
        ))}
        {fillers.map(() => <div class="post-card-filler" aria-hidden="true"></div>)}
      </div>

      <div id="no-results" class="empty-state hidden">
        <p class="empty-title">No posts found</p>
        <p class="empty-sub">Try adjusting your search or filters.</p>
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .page-workspace { display: flex; flex-direction: column; }
  .page-header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: end;
    padding: 24px 0 20px;
    border-bottom: 1px solid var(--grid-line-strong);
  }
  @media (max-width: 768px) { .page-header { grid-template-columns: 1fr; } }
  .page-header-inner { display: flex; flex-direction: column; gap: 4px; }
  .page-kicker {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--accent);
  }
  .page-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.05;
    color: var(--text-primary);
    margin: 0;
  }
  .page-sub {
    font-family: var(--font-serif, var(--font-sans));
    font-style: italic;
    font-size: 0.92rem;
    color: var(--text-secondary);
    margin: 4px 0 0;
  }
  .page-controls {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }
  .control-input {
    position: relative;
    display: flex;
    align-items: center;
  }
  .control-input input {
    background: var(--bg-base);
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 6px 28px 6px 10px;
    outline: none;
    border-radius: var(--radius);
    width: 200px;
  }
  .control-input input:focus { border-color: var(--accent); }
  .control-input svg { position: absolute; right: 8px; color: var(--text-muted); pointer-events: none; }
  .control-select {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 6px 24px 6px 10px;
    border-radius: var(--radius);
    cursor: pointer;
    outline: none;
  }
  .control-select:focus { border-color: var(--accent); }

  .grid-section { position: relative; padding: 16px 0 24px; }
  .grid-section + .grid-section { border-top: 1px solid var(--grid-line-strong); }
  .grid-section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    padding: 8px 0 12px;
  }
  .counter { color: var(--text-muted); }

  /* Featured grid */
  .featured-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    grid-auto-rows: 1fr;
    gap: 1px;
    background: var(--grid-line-strong);
    border: 1px solid var(--grid-line-strong);
  }
  @media (max-width: 900px) { .featured-grid { grid-template-columns: 1fr; grid-auto-rows: auto; } }
  .post-card--hero { grid-row: 1 / -1; grid-column: 1; }
  .post-card--sub { grid-column: 2; }
  @media (max-width: 900px) {
    .post-card--hero, .post-card--sub { grid-column: auto; grid-row: auto; }
  }

  /* Posts grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--grid-line-strong);
    border: 1px solid var(--grid-line-strong);
  }
  @media (max-width: 900px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .posts-grid { grid-template-columns: 1fr; } }

  /* Card */
  .post-card { background: var(--bg-base); display: flex; flex-direction: column; transition: background 0.2s ease; }
  .post-card:hover { background: var(--bg-surface); }
  .post-card-link {
    display: flex;
    flex-direction: column;
    flex: 1;
    text-decoration: none;
  }
  .post-card-link--row { flex-direction: row; }
  .post-thumb {
    overflow: hidden;
    background: var(--bg-base);
    border-bottom: 1px solid var(--grid-line-strong);
  }
  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease, filter 0.3s ease;
    filter: grayscale(15%);
  }
  .post-card:hover .post-thumb img { transform: scale(1.03); filter: grayscale(0%); }
  .post-thumb--hero { aspect-ratio: 16/9; }
  .post-thumb--sub {
    width: 38%;
    aspect-ratio: auto;
    flex-shrink: 0;
    border-bottom: none;
    border-right: 1px solid var(--grid-line-strong);
  }
  .post-card--cell .post-thumb { aspect-ratio: 16/9; }
  .post-card-filler { background: var(--bg-base); }
  @media (max-width: 900px) { .post-card-filler { display: none; } }
  @media (max-width: 600px) { .post-card-filler { display: none; } }

  .post-body {
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .post-badge {
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 1px 6px;
    border-radius: 3px;
    font-weight: 700;
    font-size: 0.52rem;
  }
  .post-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-primary);
    line-height: 1.25;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-title--hero {
    font-size: 1.2rem;
  }
  .post-card:hover .post-title { color: var(--accent); }
  .post-desc {
    font-size: 0.84rem;
    color: var(--text-secondary);
    line-height: 1.45;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-desc--sm { font-size: 0.78rem; -webkit-line-clamp: 2; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: auto; }
  .tg {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    padding: 2px 6px;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-muted);
  }
  .post-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 16px;
    border-top: 1px solid var(--grid-line-strong);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .post-foot-arrow { transition: transform 0.2s ease, color 0.2s ease; }
  .post-card:hover .post-foot-arrow { color: var(--accent); transform: translateX(3px); }

  .empty-state {
    padding: 40px;
    border: 1px dashed var(--grid-line-strong);
    text-align: center;
  }
  .empty-title { color: var(--text-secondary); font-weight: 600; margin: 0 0 4px; }
  .empty-sub { color: var(--text-muted); font-family: var(--font-mono); font-size: 0.7rem; }
  .hidden { display: none !important; }
</style>

<script>
  const tagSelect = document.getElementById('tag-select') as HTMLSelectElement | null;
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const cards = document.querySelectorAll<HTMLElement>('.post-card');
  const noResults = document.getElementById('no-results');

  function filterPosts() {
    const selectedTag = tagSelect?.value || 'all';
    const searchQuery = (searchInput?.value || '').toLowerCase();
    let visibleCount = 0;

    cards.forEach(card => {
      const tags = JSON.parse(card.getAttribute('data-tags') || '[]');
      const title = (card.getAttribute('data-title') || '').toLowerCase();
      const matchesTag = selectedTag === 'all' || tags.includes(selectedTag);
      const matchesSearch = title.includes(searchQuery);
      if (matchesTag && matchesSearch) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });

    if (noResults) noResults.classList.toggle('hidden', visibleCount !== 0);
  }

  tagSelect?.addEventListener('change', filterPosts);
  searchInput?.addEventListener('input', filterPosts);
</script>
