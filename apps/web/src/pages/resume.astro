---
import MainLayout from '@layouts/MainLayout.astro';
---

<MainLayout title="Resume — Fazley Rabbi">
    <main class="page-workspace">
        <header class="page-header">
            <div class="page-header-inner">
                <span class="page-kicker">/ RESUME</span>
                <h1 class="page-title">Curriculum Vitae</h1>
                <p class="page-sub">Backend Engineer · Laravel / Distributed Systems</p>
            </div>
            <button id="print-resume" class="download-btn cursor-pointer">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                Download PDF
            </button>
        </header>

        <!-- Resume Card -->
        <div class="cv-card">

            <!-- Header -->
            <div class="px-6 sm:px-10 pt-8 pb-6 border-b border-[var(--border)] text-center">
                <h2 class="font-display font-bold text-[clamp(1.4rem,3vw,1.9rem)] text-[var(--text-primary)] leading-tight">Md Fazley Rabbi</h2>
                <div class="mt-2 flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-[0.85rem] text-[var(--text-secondary)]">
                    <a href="mailto:fazley111@gmail.com" class="hover:text-[var(--accent)] transition-colors">fazley111@gmail.com</a>
                    <span class="hidden sm:inline text-[var(--text-muted)]">|</span>
                    <a href="https://linkedin.com/in/fazley-rabby" target="_blank" class="hover:text-[var(--accent)] transition-colors">linkedin.com/in/fazley-rabby</a>
                    <span class="hidden sm:inline text-[var(--text-muted)]">|</span>
                    <a href="https://github.com/fazleyrabby" target="_blank" class="hover:text-[var(--accent)] transition-colors">github.com/fazleyrabby</a>
                </div>
                <a href="https://fazleyrabbi.xyz" target="_blank" class="inline-block mt-1 text-[0.85rem] text-[var(--accent-text)] hover:underline">fazleyrabbi.xyz</a>
            </div>

            <div class="px-6 sm:px-10 py-6 cv-body">


                <!-- Work Experience -->
                <div class="cv-section">
                    <h3 class="cv-section-title">Work Experience</h3>

                    <div class="space-y-5">
                        <!-- Electronic First -->
                        <div>
                            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
                                <h4 class="font-display font-bold text-[1.1rem] text-[var(--text-primary)]">Electronic First FZ</h4>
                                <span class="font-mono text-[0.75rem] text-[var(--text-muted)] uppercase tracking-wider shrink-0">Remote, UAE</span>
                            </div>
                            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
                                <span class="text-[0.92rem] text-[var(--text-secondary)] italic">Software Engineer (Laravel)</span>
                                <span class="font-mono text-[0.75rem] text-[var(--text-muted)] tracking-wider shrink-0">Oct 2021 – Present</span>
                            </div>
                            <ul class="cv-list mt-1.5">
                                <li>Developed and maintained backend systems for a high-volume digital games marketplace processing thousands of daily orders.</li>
                                <li>Designed a multi-rule checkout fraud detection engine (IP/card/email velocity, BIN/ASN checks, bot fingerprinting, and auth-capture flow) that auto-blocks high-risk payments before fulfilment.</li>
                                <li>Eliminated manual processes by building real-time PayPal and Checkout.com dispute sync via webhooks and proxy files.</li>
                                <li>Engineered ClickHouse-backed analytics, providing dashboards for customer spending, gateway fees, and sales trends.</li>
                                <li>Designed versioned REST APIs and endpoints powering web applications, mobile apps, and customer-facing AI support bots.</li>
                                <li>Optimized application performance by introducing database read replicas for high-frequency user search and listing queries.</li>
                            </ul>
                            <p class="mt-1.5 text-[0.82rem] text-[var(--text-muted)]">
                                <span class="font-semibold text-[var(--text-secondary)]">Technologies:</span> Laravel, PHP, MySQL, ClickHouse, Redis, Checkout.com, PayPal, APIs, Docker, Linux
                            </p>
                        </div>

                        <!-- Amcoders -->
                        <div>
                            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
                                <h4 class="font-display font-bold text-[1.1rem] text-[var(--text-primary)]">Amcoders</h4>
                                <span class="font-mono text-[0.75rem] text-[var(--text-muted)] uppercase tracking-wider shrink-0">Remote, Bangladesh</span>
                            </div>
                            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
                                <span class="text-[0.92rem] text-[var(--text-secondary)] italic">Laravel Developer</span>
                                <span class="font-mono text-[0.75rem] text-[var(--text-muted)] tracking-wider shrink-0">Jan 2021 – Jul 2021</span>
                            </div>
                            <ul class="cv-list mt-1.5">
                                <li>Built a Bus Ticket booking system with Laravel 8 and Inertia.js.</li>
                                <li>Developed a CV/Portfolio builder and a Project Management System for clients.</li>
                                <li>Integrated multiple payment gateways: Razorpay, PayPal, Stripe, and Paystack.</li>
                                <li>Contributed to an E-bank banking project and interactive jQuery interfaces.</li>
                            </ul>
                            <p class="mt-1.5 text-[0.82rem] text-[var(--text-muted)]">
                                <span class="font-semibold text-[var(--text-secondary)]">Technologies:</span> Laravel, Inertia.js, MySQL, jQuery, Git
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Projects -->
                <div class="cv-section">
                    <h3 class="cv-section-title">Projects</h3>

                    <div class="space-y-4">
                        <div>
                            <h4 class="text-[1rem] text-[var(--text-primary)]">
                                <span class="font-display font-bold">Electronic First Core Platform</span>
                                <span class="text-[var(--text-muted)]"> — </span>
                                <span class="italic text-[0.9rem] text-[var(--text-secondary)]">High-volume digital retail marketplace processing thousands of daily orders</span>
                            </h4>
                            <ul class="cv-list mt-1">
                                <li>Built order checkout flows supporting card, PayPal, Coinbase, and internal e-wallet transactions.</li>
                                <li>Implemented Automated Gift Card and License Delivery flows using queue workers and stock syncing.</li>
                                <li>Developed business dashboard tools for tracking gate transaction fees, salary distributions, and store metrics.</li>
                            </ul>
                            <p class="mt-1.5 text-[0.82rem] text-[var(--text-muted)]">
                                <span class="font-semibold text-[var(--text-secondary)]">Technologies:</span> Laravel, MySQL, ClickHouse, Queue Workers, Redis, Docker
                            </p>
                        </div>

                        <div>
                            <h4 class="text-[1rem] text-[var(--text-primary)]">
                                <span class="font-display font-bold">SignalStack</span>
                                <span class="text-[var(--text-muted)]"> — </span>
                                <span class="italic text-[0.9rem] text-[var(--text-secondary)]">Real-time feed ingestion and distillation pipeline</span>
                            </h4>
                            <ul class="cv-list mt-1">
                                <li>Designed an asynchronous data pipeline using queue architecture to handle high-volume feed processing.</li>
                                <li>Built a multi-provider failover chain (local → Groq → OpenRouter) to distill feeds at near-zero inference cost.</li>
                                <li>Implemented Redis caching and automated scoring workflows to filter and tag incoming signals.</li>
                            </ul>
                            <p class="mt-1.5 text-[0.82rem] text-[var(--text-muted)]">
                                <span class="font-semibold text-[var(--text-secondary)]">Technologies:</span> Node.js, NestJS, Redis, Queue Systems, Groq, OpenRouter
                            </p>
                        </div>


                        <p class="text-[0.88rem] text-[var(--text-muted)]">
                            <span class="font-semibold text-[var(--text-secondary)]">Other Projects:</span> Hujjah (privacy-first Islamic research engine), LitePOS (POS + e-commerce), DailyLOG (personal Life OS), Larabrix (Laravel module system)
                        </p>
                    </div>
                </div>

                <!-- Technical Skills -->
                <div class="cv-section">
                    <h3 class="cv-section-title">Technical Skills</h3>
                    <div class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-1 text-[0.92rem]">
                        <span class="font-semibold text-[var(--text-primary)]">Backend</span>
                        <span class="text-[var(--text-secondary)]">Laravel, PHP, REST APIs, Livewire, CodeIgniter</span>

                        <span class="font-semibold text-[var(--text-primary)]">Frontend</span>
                        <span class="text-[var(--text-secondary)]">Alpine.js, Tailwind CSS, JavaScript, jQuery, Bootstrap</span>

                        <span class="font-semibold text-[var(--text-primary)]">Databases</span>
                        <span class="text-[var(--text-secondary)]">MySQL, ClickHouse, SQLite, Redis</span>

                        <span class="font-semibold text-[var(--text-primary)]">Infrastructure</span>
                        <span class="text-[var(--text-secondary)]">Docker, Linux, Git, GitHub Actions</span>

                        <span class="font-semibold text-[var(--text-primary)]">Integrations</span>
                        <span class="text-[var(--text-secondary)]">Payment Gateways, Webhooks, Queue Workers, LLM APIs (Groq, OpenRouter)</span>
                    </div>
                </div>

                <!-- Current Focus -->
                <div class="cv-section cv-current-focus">
                    <h3 class="cv-section-title">Current Focus</h3>
                    <ul class="cv-list">
                        <li>System design and scalable backend architecture</li>
                        <li>Async processing, queues, and event-driven systems</li>
                        <li>Real-time pipelines and data processing workflows</li>
                        <li>Infrastructure and containerized development environments</li>
                    </ul>
                </div>

                <!-- Education -->
                <div class="cv-section">
                    <h3 class="cv-section-title">Education</h3>
                    <div class="space-y-2">
                        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
                            <div>
                                <h4 class="font-display font-bold text-[1rem] text-[var(--text-primary)] uppercase tracking-wide">Port City International University</h4>
                                <span class="text-[0.9rem] text-[var(--text-secondary)] italic">B.Sc. in Computer Science & Engineering</span>
                            </div>
                            <span class="font-mono text-[0.75rem] text-[var(--text-muted)] tracking-wider shrink-0">2020</span>
                        </div>
                        <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5">
                            <div>
                                <h4 class="font-display font-bold text-[1rem] text-[var(--text-primary)] uppercase tracking-wide">Daffodil Institute of IT</h4>
                                <span class="text-[0.9rem] text-[var(--text-secondary)] italic">Diploma in Computer Technology</span>
                            </div>
                            <span class="font-mono text-[0.75rem] text-[var(--text-muted)] tracking-wider shrink-0">2016</span>
                        </div>
                    </div>
                </div>

                <!-- Languages -->
                <div class="cv-section" style="padding-bottom: 0; border: none;">
                    <h3 class="cv-section-title">Languages</h3>
                    <p class="text-[0.92rem] text-[var(--text-secondary)]">
                        <span class="font-semibold text-[var(--text-primary)]">Bengali</span> (Native),
                        <span class="font-semibold text-[var(--text-primary)]">English</span> (Fluent)
                    </p>
                </div>

            </div>
        </div>

    </main>
</MainLayout>

<script>
    document.getElementById("print-resume")?.addEventListener("click", () => window.print());
</script>

<style>
    .page-workspace { display: flex; flex-direction: column; gap: 0; max-width: 920px; margin: 0 auto; }
    .page-header {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: end;
      padding: 16px 0 12px;
      border-bottom: 1px solid var(--grid-line-strong);
    }
    .page-header-inner { display: flex; flex-direction: column; gap: 2px; }
    .page-kicker {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: var(--accent);
    }
    .page-title {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(1.5rem, 2.6vw, 2rem);
      line-height: 1.05;
      color: var(--text-primary);
      margin: 0;
    }
    .page-sub {
      font-family: var(--font-serif, var(--font-sans));
      font-style: italic;
      font-size: 0.9rem;
      color: var(--text-secondary);
      margin: 2px 0 0;
    }
    .download-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-mono);
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-primary);
      border: 1px solid var(--border);
      padding: 6px 12px;
      border-radius: var(--radius);
      background: var(--bg-surface);
      transition: all 0.2s ease;
    }
    .download-btn:hover { border-color: var(--accent); color: var(--accent); }

    .cv-card {
      background: color-mix(in srgb, var(--text-primary) 4%, var(--bg-base));
      border: 1px solid var(--grid-line-strong);
      padding: 20px 28px;
      margin-top: 16px;
    }
    .cv-card section { padding: 0 !important; }
    .cv-body {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .cv-section {
        padding-bottom: 16px;
        border-bottom: 1px solid var(--grid-line-strong);
    }

    .cv-section:last-child {
        padding-bottom: 0;
        border-bottom: none;
    }

    .cv-section-title {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent-text);
        padding-bottom: 4px;
        margin-bottom: 8px;
        border-bottom: 1px solid var(--grid-line-strong);
    }

    .cv-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .cv-list li {
        position: relative;
        padding-left: 14px;
        font-size: 0.84rem;
        line-height: 1.5;
        color: var(--text-secondary);
    }

    .cv-list li::before {
        content: "›";
        position: absolute;
        left: 0;
        color: var(--accent);
    }

    /* Compact internal sizes */
    .cv-card :global(h2) { font-size: 1.4rem !important; }
    .cv-card :global(h3.cv-section-title) { font-size: 0.68rem !important; }
    .cv-card :global(h4) { font-size: 0.95rem !important; }
    .cv-card :global(p), .cv-card :global(span), .cv-card :global(div) { font-size: 0.86rem; }
    .cv-card :global(.font-mono) { font-size: 0.68rem !important; }

    @media (max-width: 640px) {
        .page-header {
            padding: 12px 4px 8px;
        }
        .cv-card {
            padding: 12px 14px;
            margin-top: 8px;
        }
        .cv-card > div:first-child {
            padding-left: 12px !important;
            padding-right: 12px !important;
            padding-top: 16px !important;
            padding-bottom: 12px !important;
        }
        .cv-body {
            padding-left: 12px !important;
            padding-right: 12px !important;
            padding-top: 12px !important;
            padding-bottom: 12px !important;
            gap: 12px;
        }
        .cv-section {
            padding-bottom: 12px;
        }
    }

    @media print {
        @page {
            size: A4;
            margin: 8mm 10mm;
        }

        :global(*),
        :global(*::before),
        :global(*::after),
        :global(html[data-theme] *),
        :global(html[data-theme] *::before),
        :global(html[data-theme] *::after) {
            background: none !important;
            background-color: transparent !important;
            background-image: none !important;
            box-shadow: none !important;
            text-shadow: none !important;
            color-scheme: light !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            color: #000000 !important;
            -webkit-text-fill-color: #000000 !important;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif !important;
        }

        :global(a),
        :global(a *),
        :global(html[data-theme] a),
        :global(html[data-theme] a *) {
            color: #0056b3 !important;
            -webkit-text-fill-color: #0056b3 !important;
            text-decoration: underline !important;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif !important;
        }

        :global(html),
        :global(body) {
            background: #fff !important;
            color: #000000 !important;
            overflow: visible !important;
            height: auto !important;
            min-height: auto !important;
            position: static !important;
            font-size: 9.2pt !important;
            line-height: 1.35 !important;
        }


        /* Override layout scroll wrappers to prevent content truncation */
        :global(.scroll-container),
        :global(.workspace-shell),
        :global(.page-workspace),
        :global(.flex-1),
        :global(.flex),
        :global(main) {
            overflow: visible !important;
            height: auto !important;
            min-height: auto !important;
            max-height: none !important;
            position: static !important;
            display: block !important;
            padding: 0 !important;
            margin: 0 !important;
            width: 100% !important;
        }

        :global(.left-rail),
        :global(.top-system-bar),
        :global(footer),
        :global(.page-header),
        :global(.download-btn),
        :global(.page-gradient-layer),
        :global(.grid-overlay),
        :global(.cursor),
        :global(#scroll-to-top),
        :global(.scroll-to-top-btn),
        :global(#mobile-drawer),
        :global(.page-workspace > *::before),
        :global(.page-workspace > *::after),
        .page-header,
        .download-btn,
        .cv-current-focus {
             display: none !important;
             content: none !important;
        }

        .cv-card {
            border: none !important;
            background: transparent !important;
            margin: 0 !important;
            padding: 0 !important;
            box-shadow: none !important;
            color: #000000 !important;
        }

        .cv-card :global(h2) {
            font-size: 1.45rem !important;
            margin-bottom: 2px !important;
        }

        .cv-card > div:first-child {
            padding-top: 0 !important;
            padding-bottom: 6px !important;
            margin-bottom: 4px !important;
            border-bottom: none !important;
        }

        .cv-body {
            padding-top: 0 !important;
            padding-bottom: 0 !important;
            gap: 8px !important;
        }

        .cv-section {
            padding-bottom: 8px !important;
            margin-bottom: 4px !important;
            border-bottom: none !important;
        }

        .cv-section:last-of-type {
            border-bottom: none !important;
            padding-bottom: 0 !important;
            margin-bottom: 0 !important;
        }

        .cv-section-title {
            font-size: 7.2pt !important;
            margin-bottom: 4px !important;
            padding-bottom: 2px !important;
            border-bottom: 0.5px solid #000000 !important;
            color: #000000 !important;
        }

        .cv-list li {
            font-size: 8.4pt !important;
            line-height: 1.3 !important;
            margin-bottom: 1px !important;
            padding-left: 10px !important;
        }

        .cv-list li::before {
            content: "•" !important;
            font-size: 8.4pt !important;
            color: #000000 !important;
            left: 0 !important;
        }

        .cv-card :global(h4) {
            font-size: 9.5pt !important;
        }

        .cv-card :global(p),
        .cv-card :global(span),
        .cv-card :global(div) {
            color: #000000 !important;
            font-size: 8.6pt !important;
        }

        .cv-card :global(a) {
            color: #0056b3 !important;
            text-decoration: underline !important;
            font-size: 8.6pt !important;
        }

        .cv-card :global(.text-\[0\.82rem\]),
        .cv-card :global(.text-\[var\(--text-secondary\)\]),
        .cv-card :global(.text-\[var\(--text-muted\)\]),
        .cv-card :global(span.font-mono) {
            color: #000000 !important;
            font-size: 8.2pt !important;
        }

        /* Tighten spacing between list items and headers */
        .cv-section :global(.space-y-5),
        .cv-section :global(.space-y-4) {
            margin-top: 2px !important;
        }
        .cv-section :global(.space-y-5 > * + *),
        .cv-section :global(.space-y-4 > * + *),
        .cv-section :global(.space-y-2 > * + *) {
            margin-top: 5px !important;
        }
    }
</style>
