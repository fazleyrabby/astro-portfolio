<form
    class="max-w-full"
    id="contactForm"
>
    <div class="relative z-0 w-full mb-6 group">
        <input
            type="email"
            name="email"
            id="email"
            class="custom-input peer"
            placeholder=" "
            required
        />
        <label for="email" class="custom-label">Email address</label>
    </div>
    <div class="relative z-0 w-full mb-6 group">
        <textarea
            name="message"
            id="message"
            class="custom-input peer"
            placeholder=" "
            rows="4"
            required
        ></textarea>
        <label for="message" class="custom-label">Message</label>
    </div>
    <button type="submit" class="submit-btn">Submit</button>
</form>

<style>
    .custom-input {
        display: block;
        padding: 10px 0;
        width: 100%;
        font-size: 0.9rem;
        background: transparent;
        border: none;
        border-bottom: 2px solid var(--border);
        appearance: none;
        color: var(--text-primary);
        transition: border-color 0.2s ease;
    }
    .custom-input:focus {
        outline: none;
        border-bottom-color: var(--accent);
    }

    .custom-label {
        position: absolute;
        top: 10px;
        left: 0;
        font-size: 0.9rem;
        color: var(--text-muted);
        transition: all 0.2s ease;
        pointer-events: none;
    }
    .custom-input:focus ~ .custom-label,
    .custom-input:not(:placeholder-shown) ~ .custom-label {
        transform: translateY(-20px) scale(0.75);
        color: var(--accent);
    }

    .submit-btn {
        background: var(--accent);
        color: #080808;
        font-weight: 700;
        font-size: 0.85rem;
        padding: 12px 28px;
        border-radius: 2px;
        border: none;
        cursor: pointer;
        transition: transform 0.2s ease, filter 0.2s ease;
    }
    .submit-btn:hover {
        transform: scale(1.04);
        filter: brightness(1.1);
    }
</style>

<script is:inline>
    document.getElementById("contactForm").addEventListener("submit", (e) => {
        e.preventDefault();
        const email = document.getElementById("email");
        const message = document.getElementById("message");

        if (email.value === "" || message.value === "") {
            alert("Email and Message is required!");
            return;
        }

        fetch("/api/contact", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                email: email.value,
                message: message.value,
            }),
        })
        .then((res) => {
            if (res.ok || res.status === 201) {
                window.location.href = "/contact-success";
            } else {
                alert("Something went wrong. Please try again.");
            }
        })
        .catch(() => alert("Something went wrong. Please try again."));
    });
</script>
