---
import AsciiAvatar from "./AsciiAvatar.astro";
---

<section
  id="hero"
  class="hero-section min-h-[85svh] relative flex items-center overflow-hidden pt-20 pb-20"
>
  <!-- Cursor-reactive light -->
  <div class="hero-cursor-light" aria-hidden="true"></div>

  <!-- Breathing glow -->
  <div class="hero-breathe" aria-hidden="true"></div>

  <!-- Diagonal grid - subtle -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.03] dark:opacity-[0.05]"
    style="background-image:linear-gradient(var(--text-primary) 1px,transparent 1px),linear-gradient(90deg,var(--text-primary) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 40%,transparent 100%);"
    aria-hidden="true"
  >
  </div>

  <!-- Smooth merge fade at bottom -->
  <div
    class="absolute bottom-0 left-0 right-0 h-56 pointer-events-none z-20"
    style="background: linear-gradient(to bottom, transparent 0%, var(--bg-base) 100%);"
  >
  </div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6">
    <div class="hero-grid">
      <div class="max-w-2xl relative z-10">
        <div class="badge-pill">
          <span class="badge-dot"></span>
          Available for freelance & collaboration
        </div>

        <h1 class="mb-1">
          <span class="block">Hi, I'm</span>
          <span>Fazley Rabbi</span
          >
        </h1>

        <p class="hero-tagline font-serif italic">
          Building tools and systems that make software faster, cleaner, and
          more reliable.
        </p>

        <p class="hero-body max-w-[550px] font-sans mt-4">
          With 4+ years of experience, I build scalable applications, client
          solutions, and commercial products. My
          work focuses on clean architecture, performance, and long-term
          maintainability. Currently developing SignalStack and Xentari to
          improve developer workflows and system stability.
        </p>

        <div class="flex gap-3 flex-wrap mt-8">
          <a href="/resume" class="btn-primary btn-magnetic">Resume</a>
          <a href="#projects" class="btn-ghost">View Projects</a>
        </div>

        <div class="connect-block mt-8">
          <span class="section-label font-mono" style="margin-bottom:0.4rem;"
            >Connect</span
          >
          <div class="flex gap-5">
            <a
              href="https://github.com/fazleyrabby"
              target="_blank"
              class="link-underline text-[var(--text-secondary)] text-[0.7rem] font-mono uppercase tracking-wider"
              >GitHub</a
            >
            <a
              href="https://www.linkedin.com/in/fazley-rabby/"
              target="_blank"
              class="link-underline text-[var(--text-secondary)] text-[0.7rem] font-mono uppercase tracking-wider"
              >LinkedIn</a
            >
            <a
              href="mailto:fazley111@gmail.com"
              class="link-underline text-[var(--text-secondary)] text-[0.7rem] font-mono uppercase tracking-wider"
              >Email</a
            >
          </div>
        </div>
      </div>

      <div class="hero-avatar-col">
        <AsciiAvatar />
      </div>
    </div>
  </div>

  <!-- Scroll Down Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-30 opacity-50 hidden md:block">
    <div class="flex flex-col items-center gap-2">
      <span class="font-mono text-[0.6rem] uppercase tracking-widest text-[var(--text-muted)]">Scroll</span>
      <div class="w-[1px] h-12 bg-gradient-to-b from-accent to-transparent"></div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    background: var(--bg-base);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: 2rem;
    position: relative;
  }

  @media (min-width: 1025px) {
    .hero-grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 4rem;
    }
  }

  .hero-avatar-col {
    display: flex;
    position: absolute;
    inset: 0;
    justify-content: center;
    align-items: center;
    opacity: 0.15;
    z-index: -1;
    pointer-events: none;
  }

  @media (min-width: 1025px) {
    .hero-avatar-col {
      position: relative;
      opacity: 1;
      inset: auto;
      min-height: 500px;
      margin-left: 0;
      margin-right: 0;
      z-index: 1;
      pointer-events: auto;
    }
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.2;
    color: var(--text-primary);
  }

  .hero-name {
    padding-bottom: 0.15em;
  }

  .hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--text-secondary);
    margin-top: 0;
    margin-bottom: 1.25rem;
  }

  .hero-body {
    font-size: clamp(0.92rem, 1.8vw, 1rem);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse-dot 2s ease infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.8);
    }
  }

  .hero-breathe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 500px;
    height: 500px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(
      circle,
      var(--accent-dim) 0%,
      transparent 70%
    );
    pointer-events: none;
    animation: breathe 10s ease-in-out infinite;
  }

  @keyframes breathe {
    0%,
    100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.3;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.1);
      opacity: 0.5;
    }
  }

  .hero-cursor-light {
    position: fixed;
    width: 350px;
    height: 350px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      var(--accent-dim) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
    transform: translate(-50%, -50%);
    mix-blend-mode: plus-lighter;
  }
</style>
