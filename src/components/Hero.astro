---
---

<section class="hero relative min-h-[100svh] flex items-center overflow-hidden py-20">
  <!-- Section Index -->
  <div class="absolute top-20 right-5 text-[0.6rem] text-[var(--text-muted)]">01</div>

  <div class="container mx-auto px-4 md:px-8 relative z-10 w-full">
    <!-- Status Badge -->
    <div class="hero-badge mb-8">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full bg-[var(--accent)] opacity-75 rounded-full"></span>
        <span class="relative inline-flex h-2 w-2 bg-[var(--accent)] rounded-full"></span>
      </span>
      Available for freelance & collaboration
    </div>

    <!-- Headline -->
    <h1 class="font-serif font-extrabold text-[clamp(2.5rem,6vw,5rem)] mb-6 leading-[1.05] tracking-tight text-[var(--text-primary)]">
      <span class="hero-word">Hi,</span>
      <span class="hero-word">I'm</span>
      <span class="hero-word hero-name">Fazley</span>
      <span class="hero-word">Rabbi</span>
    </h1>

    <!-- Tagline -->
    <p class="italic text-xl md:text-2xl mb-8 text-[var(--text-secondary)]">
      A passionate web developer & tech enthusiast from Bangladesh.
    </p>

    <!-- Description -->
    <p class="text-sm mb-10 leading-[1.85] max-w-[520px] text-[var(--text-secondary)]">
      I build backend systems that scale — REST APIs, SaaS platforms, payment
      integrations, and Docker-deployed Laravel applications. Based in Bangladesh,
      working with clients globally.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap gap-4 mb-10">
      <a href="/about#contact" class="btn-primary">Hire Me</a>
      <a href="#projects" class="btn-ghost">View Work</a>
    </div>

    <!-- Connect Links -->
    <div class="flex flex-wrap gap-6 text-[0.72rem] uppercase">
      <a href="https://github.com/fazleyrabby" target="_blank" class="connect-link text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">GitHub</a>
      <a href="https://www.linkedin.com/in/fazley-rabby/" target="_blank" class="connect-link text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">LinkedIn</a>
      <a href="mailto:fazley111@gmail.com" class="connect-link text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">Email</a>
    </div>
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(ellipse 65% 55% at 15% 110%, rgba(232,130,58,0.09) 0%, transparent 65%),
      radial-gradient(ellipse 40% 40% at 85% -10%, rgba(232,130,58,0.05) 0%, transparent 60%),
      var(--bg-base);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(128,128,128,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(128,128,128,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-left: 3px solid var(--accent);
    background: var(--accent-dim);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-secondary);
  }

  .hero-word {
    display: inline-block;
    overflow: hidden;
  }

  .hero-name {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 10px;
  }

  .btn-primary {
    background: var(--accent);
    color: #080808;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 12px 28px;
    border-radius: 2px;
    transition: transform 0.2s var(--ease-out-expo), filter 0.2s ease;
  }

  .btn-primary:hover {
    filter: brightness(1.1);
  }

  .btn-ghost {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border);
    font-weight: 600;
    font-size: 0.85rem;
    padding: 12px 28px;
    border-radius: 2px;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .connect-link::after {
    content: ' \2192';
    transition: padding-left 0.2s ease;
  }

  .connect-link:hover::after {
    padding-left: 4px;
  }
</style>
