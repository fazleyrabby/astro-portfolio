---
import { getCollection } from 'astro:content';
const allPosts = await getCollection('posts');
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestPosts = allPosts.slice(0, 3);
---

<section class="py-20">
  <div class="mb-12">
    <div class="section-label">05 / WRITING</div>
    <div class="section-header-row">
      <h2 class="section-heading">Latest Posts</h2>
      <div class="section-rule"></div>
    </div>
  </div>

  <div class="posts-list">
    {latestPosts.map((post, index) => (
      <a href={`/posts/${post.slug}`} class="post-row">
        <span class="post-num">{String(index + 1).padStart(2, '0')}</span>
        <span class="post-date">
          {post.data.date ? new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'Unknown'}
        </span>
        <span class="post-title">{post.data.title}</span>
        <span class="post-arrow">&#8594;</span>
      </a>
    ))}
  </div>

  {latestPosts.length === 0 && (
    <div class="text-center py-16">
      <p class="text-[var(--text-muted)]">No posts yet. Check back soon!</p>
    </div>
  )}

  {latestPosts.length > 0 && (
    <div class="mt-10 text-center">
      <a href="/posts" class="show-more">Show More Posts</a>
    </div>
  )}
</section>

<style>
  .post-row {
    display: grid;
    grid-template-columns: 36px 110px 1fr 24px;
    align-items: center;
    gap: 20px;
    padding: 18px 8px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.2s ease, padding-left 0.2s ease;
  }
  .post-row:hover {
    background: var(--accent-dim);
    padding-left: 16px;
  }
  .post-num {
    font-size: 0.72rem;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }
  .post-row:hover .post-num { color: var(--accent); }
  .post-date {
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .post-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
  }
  .post-arrow {
    font-size: 1rem;
    color: var(--text-secondary);
    transition: transform 0.2s ease;
  }
  .post-row:hover .post-arrow { transform: translateX(5px); }
</style>
