---
import { Image } from "astro:assets";
const { project } = Astro.props;
const { title, tech, live, github, thumbnail, description, type } = project.data;
---

<article class="project-card group flex flex-col bg-[var(--bg-card)] border border-[var(--border)] overflow-hidden h-full">
  <!-- Thumbnail -->
  <a href={live || github || "#"} target="_blank" rel="noreferrer" aria-label={title}
     class="block relative overflow-hidden aspect-video flex-shrink-0">
    {thumbnail && (
      <>
        <Image
          src={thumbnail}
          class="object-cover object-left-top w-full h-full transition-all duration-700 grayscale-[20%] group-hover:grayscale-0 group-hover:scale-105"
          alt={`${title} screenshot`}
          width={600} height={300} loading="lazy"
        />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300" />
      </>
    )}
    {type && <span class="tag absolute top-3 right-3">{type}</span>}
  </a>

  <!-- Content -->
  <div class="flex flex-col flex-grow p-6">
    <h3 class="font-display font-bold text-xl text-[var(--text-primary)] mb-3 group-hover:text-[var(--accent)] transition-colors">
      {title}
    </h3>

    <p class="text-[0.9rem] text-[var(--text-secondary)] mb-6 line-clamp-3 leading-relaxed">
      {description}
    </p>

    <!-- Tech Stack -->
    <div class="flex gap-2 flex-wrap mb-6 mt-auto">
      {tech?.map((t: string) => <span class="tag">{t}</span>)}
    </div>

    <!-- Actions -->
    <div class="flex gap-4">
      {live && (
        <a class="flex-1 inline-flex items-center justify-center gap-2 py-2.5 text-xs font-bold uppercase tracking-wider bg-[var(--accent)] text-[#080808] rounded-[2px] transition-all hover:brightness-110 active:scale-95 btn-magnetic"
           href={live} target="_blank">Live Demo</a>
      )}
      {github && (
        <a class="flex-1 inline-flex items-center justify-center gap-2 py-2.5 text-xs font-bold uppercase tracking-wider border border-[var(--border)] text-[var(--text-primary)] rounded-[2px] transition-all hover:border-[var(--accent)] hover:text-[var(--accent)] active:scale-95 btn-magnetic"
           href={github} target="_blank">Repo</a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.4s var(--ease-out-expo);
  }
  .project-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--accent-glow);
    transform: translateY(-5px);
  }
</style>
