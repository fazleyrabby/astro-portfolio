---
import { getCollection } from 'astro:content';
import ProjectCard from "./ProjectCard.astro";

const { type } = Astro.props;
const projects = await getCollection('projects');
projects.sort((a, b) => (a.data.position || 0) - (b.data.position || 0));

const displayProjects = type === "home"
  ? projects.filter(p => p.data.featured)
  : projects;
---

<section class="py-20" id={type === "home" ? "projects" : ""}>
  <div class="mb-12">
    <div class="section-label">02 / PROJECTS</div>
    <div class="section-header-row">
      <h2 class="section-heading">Featured Projects</h2>
      <div class="section-rule"></div>
    </div>
  </div>

  <div class={`grid gap-8 ${type === "home" ? "md:grid-cols-2" : "md:grid-cols-2 lg:grid-cols-3"}`}>
    {displayProjects.map((item) => <ProjectCard project={item} />)}
  </div>

  {type === "home" && (
    <div class="mt-12 text-center">
      <a href="/projects" class="show-more">View all projects</a>
    </div>
  )}
</section>
