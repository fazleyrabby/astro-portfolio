---
const skillGroups = [
  { label: "Backend",  skills: ["PHP", "Laravel", "MySQL", "REST API", "Database Design"] },
  { label: "DevOps",   skills: ["Docker", "Netlify", "GitHub", "CI/CD", "VPS Management"] },
  { label: "Frontend", skills: ["JavaScript", "Tailwind CSS", "Bootstrap", "jQuery"] },
  { label: "Tooling",  skills: ["Astro", "Markdown", "Postman", "Git"] }
];
---

<!-- Skills Section -->
<section id="skills" class="reveal py-16">
  <!-- Section Header -->
  <div class="mb-10">
    <span class="text-indigo-600 dark:text-indigo-400 text-sm font-semibold uppercase tracking-wider mb-2 block">Expertise</span>
    <h2 class="text-3xl md:text-5xl font-bold font-serif text-gray-900 dark:text-white mb-2">
      Skills & Technologies
    </h2>
    <p class="text-zinc-500 dark:text-zinc-400 max-w-xl">
      Technologies I work with to bring ideas to life.
    </p>
  </div>

  <!-- Skills Grid -->
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 stagger">
    {skillGroups.map(group => (
      <div class="space-y-4">
        <p class="text-[10px] font-bold text-zinc-400 dark:text-zinc-500 uppercase tracking-[0.2em] mb-4">{group.label}</p>
        <div class="flex flex-wrap gap-2">
          {group.skills.map(s => (
            <span class="text-sm px-3 py-1.5 bg-white/50 dark:bg-zinc-900/50 backdrop-blur-sm text-zinc-700 dark:text-zinc-300 rounded-xl border border-zinc-200 dark:border-zinc-800 hover:border-indigo-400 dark:hover:border-indigo-500 transition-colors shadow-sm">
              {s}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
