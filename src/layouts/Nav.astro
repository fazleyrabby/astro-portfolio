---
import ThemeIcon from "@components/ThemeIcon.astro";

const navItems = [
    { href: "/#projects", label: "Work" },
    { href: "/posts/", label: "Blog" },
    { href: "/about/", label: "About" },
];
---

<header class="sticky top-0 z-50 w-full backdrop-blur-xl border-b border-[var(--border)]" style="background: color-mix(in srgb, var(--bg-base) 85%, transparent);">
    <nav class="max-w-6xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-2 group">
                <span class="text-xl text-[var(--text-primary)] font-display font-bold tracking-tight">
                    Fazley<span class="text-[var(--accent)]">.</span>
                </span>
            </a>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center gap-8">
                {navItems.map((item) => (
                    <a href={item.href} class="nav-link-item text-[0.75rem] font-mono uppercase tracking-[0.08em] text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors relative py-1">
                        {item.label}
                    </a>
                ))}
                
                <div class="flex items-center gap-2 ml-4 px-3 py-1.5 border border-[var(--border)] rounded-full bg-[var(--bg-surface)]">
                    <span class="avail-dot"></span>
                    <span class="font-mono text-[0.7rem] text-[var(--text-muted)] uppercase tracking-wider">Available</span>
                </div>

                <div class="ml-2 pl-4 border-l border-[var(--border)]">
                    <ThemeIcon />
                </div>
            </div>

            <!-- Mobile Menu Button -->
            <div class="flex md:hidden items-center gap-4">
                <ThemeIcon />
                <button id="mobile-menu-button" class="p-2 text-[var(--text-secondary)] hover:text-[var(--accent)]" aria-label="Toggle menu">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 space-y-4 border-t border-[var(--border)] pt-4">
            {navItems.map((item) => (
                <a href={item.href} class="block text-sm font-mono uppercase tracking-widest text-[var(--text-secondary)] hover:text-[var(--accent)] transition-colors">
                    {item.label}
                </a>
            ))}
        </div>
    </nav>
</header>

<style>
    .nav-link-item::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--accent);
        transition: width var(--t-mid) var(--ease-out-expo);
    }
    .nav-link-item:hover::after,
    .nav-link-item.nav-active::after {
        width: 100%;
    }

    .avail-dot {
        width: 6px;
        height: 6px;
        background: #4ade80;
        border-radius: 50%;
        display: inline-block;
        animation: pulse-dot 2s ease infinite;
    }
    @keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }
</style>

<script>
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    mobileMenuButton?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
    });
</script>
