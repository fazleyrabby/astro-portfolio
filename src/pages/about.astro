---
import MainLayout from "@layouts/MainLayout.astro";
import Github from "@components/Icons/Github.astro";
import Youtube from "@components/Icons/Youtube.astro";
import Email from "@components/Icons/Email.astro";
import Codepen from "@components/Icons/Codepen.astro";
import Linkedin from "@components/Icons/Linkedin.astro";
import { Content as AboutMarkdown } from "../content/about.md";
import ContactForm from "@components/ContactForm.astro";
---

<MainLayout title="About">
  <main class="container mx-auto px-4 md:px-8 py-8 max-w-[800px]">
    <div class="section-label">About</div>
    <h1 class="page-heading">About Fazley Rabbi</h1>

    <section class="mb-12 text-[var(--text-secondary)] leading-[1.8]">
      <div class="prose w-full">
        <AboutMarkdown />
      </div>
    </section>

    <div id="contact" class="mt-12">
      <h2 class="font-serif font-bold text-2xl text-[var(--text-primary)] mb-6">Send me a message</h2>
      <div class="card p-6 rounded mb-8">
        <ContactForm />
      </div>
    </div>

    <hr class="border-none border-t border-[var(--border)] my-12" />

    <p class="text-xs text-[var(--text-muted)] text-center mb-4">Or Connect with me on</p>
    <div class="flex gap-4 icons justify-center mb-6">
      <Github />
      <Linkedin />
      <Youtube />
      <Email />
      <Codepen />
    </div>
  </main>
</MainLayout>
