---
// src/pages/posts/[slug].astro
export const prerender = true;

import MainLayout from "@layouts/MainLayout.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const publishedPosts = posts.filter((post) => !post.data.draft);
  return publishedPosts.map((post) => ({
    params: { slug: post.id.replace(/\.mdx?$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<MainLayout 
  title={post.data.title}
  ogTitle={post.data.title}
  ogDescription={post.data.title}
  ogImage={post.data.thumbnail}
  ogUrl={`https://fazleyrabbi.xyz/posts/${post.id.replace(/\.mdx?$/, "")}`}
  ogType="article"
  twitterCard="summary_large_image"
  twitterImage={post.data.thumbnail}
>
  <main class="max-w-6xl mx-auto px-6 py-16">
    <!-- Hero: thumbnail + title (full width, above the grid) -->
    <div class="max-w-3xl mx-auto lg:mx-0 lg:max-w-none mb-12">
      {post.data.thumbnail && (
        <div class="relative w-full rounded-[1.5rem] mb-8 overflow-hidden flex justify-center items-center" data-thumb-container>
          <img 
            data-thumb 
            src={post.data.thumbnail} 
            alt={post.data.title} 
            class="max-h-[400px] w-auto max-w-full object-contain" 
            style="-webkit-mask-image: linear-gradient(to right, transparent, black 60px, black calc(100% - 60px), transparent); mask-image: linear-gradient(to right, transparent, black 60px, black calc(100% - 60px), transparent);"
            loading="lazy" 
          />
        </div>
      )}
      <h1 class="font-display font-bold text-[clamp(2rem,5vw,3.5rem)] text-[var(--text-primary)] mb-4">{post.data.title}</h1>
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 flex-wrap mb-4">
        <p class="mb-0">
          <small class="font-mono text-xs text-[var(--text-muted)] uppercase tracking-widest"
            >{
              post.data.date ? new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : ""
            }</small
          >
        </p>
        
        {post.data.tags && post.data.tags.length > 0 && (
          <>
            <span class="hidden sm:inline-block text-[var(--border-color)]">|</span>
            <div class="flex items-center gap-2 flex-wrap">
              {post.data.tags.map((tag) => (
                <span class="px-2.5 py-1 text-[10px] font-mono tracking-widest uppercase rounded-full bg-[var(--surface-color)] border border-[var(--border-color)] text-[var(--text-secondary)]">
                  {tag}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
    </div>

    <!-- Content grid: article + TOC sidebar -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
      <article id="article-content" class="lg:col-span-8 prose prose-neutral dark:prose-invert max-w-none prose-p:text-[var(--text-secondary)] prose-p:leading-relaxed prose-li:text-[var(--text-secondary)] prose-headings:font-display prose-headings:font-bold prose-headings:text-[var(--text-primary)] prose-strong:text-[var(--text-primary)] prose-strong:font-semibold prose-blockquote:text-[var(--text-secondary)] prose-blockquote:border-[var(--accent)]">
        <Content />
      </article>
      <TableOfContents />
    </div>
  </main>
</MainLayout>

<script>
  const img = document.querySelector('img[data-thumb]') as HTMLImageElement | null;
  if (img) {
    const cacheKey = `thumb-bg:${img.src}`;
    const cached = sessionStorage.getItem(cacheKey);

    const applyColor = (color: string) => {
      const container = document.querySelector('[data-thumb-container]') as HTMLElement | null;
      if (container) {
        container.style.backgroundColor = color;
        container.style.setProperty('--edge-color', color);
      }
    };

    if (cached) {
      applyColor(cached);
    } else {
      const detectBg = () => {
        const proxy = new Image();
        proxy.crossOrigin = 'anonymous';
        proxy.src = `/api/image-proxy?url=${encodeURIComponent(img.src)}`;
        proxy.onload = () => {
          try {
            const c = document.createElement('canvas');
            const ctx = c.getContext('2d');
            if (!ctx) return;
            const w = proxy.naturalWidth;
            const h = proxy.naturalHeight;
            c.width = w;
            c.height = h;
            ctx.drawImage(proxy, 0, 0);

            let r = 0, g = 0, b = 0, count = 0;
            const sample = (x: number, y: number) => {
              const d = ctx.getImageData(x, y, 1, 1).data;
              r += d[0]; g += d[1]; b += d[2]; count++;
            };
            const step = Math.max(1, Math.floor(Math.max(w, h) / 20));
            for (let x = 0; x < w; x += step) { sample(x, 0); sample(x, h - 1); }
            for (let y = 0; y < h; y += step) { sample(0, y); sample(w - 1, y); }

            const color = `rgb(${Math.round(r / count)}, ${Math.round(g / count)}, ${Math.round(b / count)})`;
            applyColor(color);
            sessionStorage.setItem(cacheKey, color);
          } catch {
            applyColor('#000');
          }
        };
        proxy.onerror = () => { applyColor('#000'); };
      };
      if (img.complete) detectBg();
      else img.addEventListener('load', detectBg);
    }
  }
</script>

<script>
  // Wrap code blocks with a proper header for sticky dots + badge + copy button
  document.querySelectorAll('#article-content pre').forEach((pre) => {
    // Skip if already wrapped
    if (pre.parentElement?.classList.contains('code-block-wrapper')) return;

    const lang = pre.getAttribute('data-language') || '';

    // Create wrapper
    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper';

    // Create sticky header
    const header = document.createElement('div');
    header.className = 'code-block-header';

    // macOS dots
    const dots = document.createElement('div');
    dots.className = 'code-block-dots';
    dots.innerHTML = '<span class="dot dot-red"></span><span class="dot dot-yellow"></span><span class="dot dot-green"></span>';
    header.appendChild(dots);

    // Right side: language badge + copy button
    const rightSide = document.createElement('div');
    rightSide.className = 'code-block-right';

    // Language badge
    if (lang) {
      const badge = document.createElement('span');
      badge.className = 'code-block-lang';
      badge.textContent = lang.toUpperCase();
      rightSide.appendChild(badge);
    }

    // Copy button
    const copyBtn = document.createElement('button');
    copyBtn.className = 'code-block-copy';
    copyBtn.setAttribute('aria-label', 'Copy code');
    copyBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg><span class="copy-text">Copy</span>`;
    copyBtn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const code = pre.querySelector('code')?.innerText || pre.innerText;
      try {
        await navigator.clipboard.writeText(code);
        copyBtn.classList.add('copied');
        copyBtn.querySelector('.copy-text')!.textContent = 'Copied!';
        setTimeout(() => {
          copyBtn.classList.remove('copied');
          copyBtn.querySelector('.copy-text')!.textContent = 'Copy';
        }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
    rightSide.appendChild(copyBtn);

    // Expand button
    const expandBtn = document.createElement('button');
    expandBtn.className = 'code-block-expand';
    expandBtn.setAttribute('aria-label', 'Expand code');
    expandBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M14 10l6.1-6.1M9 21H3v-6M10 14l-6.1 6.1"/></svg>`;
    expandBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      openCodeModal(pre, lang);
    });
    rightSide.appendChild(expandBtn);

    header.appendChild(rightSide);

    // Insert wrapper before pre, then move pre inside
    pre.parentNode!.insertBefore(wrapper, pre);
    wrapper.appendChild(header);
    wrapper.appendChild(pre);

    // Only trap scroll when the code block actually overflows
    const isScrollable = () => pre.scrollHeight > pre.clientHeight;
    wrapper.addEventListener('mouseenter', () => { if (isScrollable()) document.body.style.overflow = 'hidden'; });
    wrapper.addEventListener('mouseleave', () => { document.body.style.overflow = ''; });
    wrapper.addEventListener('wheel', (e) => { if (isScrollable()) e.stopPropagation(); }, { passive: true });
    wrapper.addEventListener('touchmove', (e) => { if (isScrollable()) e.stopPropagation(); }, { passive: true });
  });

  function openCodeModal(pre: Element, lang: string) {
    const code = pre.querySelector('code')?.innerText || pre.innerText;
    const modal = document.createElement('div');
    modal.className = 'code-modal-overlay';
    modal.innerHTML = `
      <div class="code-modal-content">
        <div class="code-modal-header">
          <span class="code-modal-lang">${lang.toUpperCase()}</span>
          <div class="code-modal-actions">
            <button class="code-modal-copy" data-code="${encodeURIComponent(code)}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
              Copy
            </button>
            <button class="code-modal-close">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
          </div>
        </div>
        <pre class="code-modal-pre"><code>${code}</code></pre>
      </div>
    `;
    document.body.appendChild(modal);
    document.body.style.overflow = 'hidden';
    
    const modalPre = modal.querySelector('.code-modal-pre') as HTMLElement;
    modalPre.addEventListener('wheel', (e) => e.stopPropagation(), { passive: true });
    modalPre.addEventListener('touchmove', (e) => e.stopPropagation(), { passive: true });
    
    modal.addEventListener('wheel', (e) => e.stopPropagation(), { passive: true });
    modal.addEventListener('touchmove', (e) => e.stopPropagation(), { passive: true });
    
    modal.querySelector('.code-modal-close')?.addEventListener('click', () => closeCodeModal(modal));
    modal.querySelector('.code-modal-copy')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const code = decodeURIComponent(btn.getAttribute('data-code') || '');
      try {
        await navigator.clipboard.writeText(code);
        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Copied!`;
        setTimeout(() => {
          btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg> Copy`;
        }, 2000);
      } catch (err) { console.error('Failed to copy:', err); }
    });
    modal.addEventListener('click', (e) => { if (e.target === modal) closeCodeModal(modal); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeCodeModal(modal); });
  }

  function closeCodeModal(modal: Element) {
    document.body.style.overflow = '';
    modal.remove();
  }
</script>
