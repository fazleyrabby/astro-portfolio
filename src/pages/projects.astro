---
import { getCollection } from 'astro:content';
import MainLayout from '@layouts/MainLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';

const projects = await getCollection('projects');
// Sort by position
projects.sort((a, b) => (a.data.position || 0) - (b.data.position || 0));

const mainProjects = projects.filter(p => p.data.type !== 'frontend');
const frontendProjects = projects.filter(p => p.data.type === 'frontend');
---

<MainLayout title="Projects — Fazley Rabbi">
  <main class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-14">
        <span class="section-label">Projects</span>
        <h1 class="font-display font-bold text-[clamp(2.5rem,6vw,4rem)] text-[var(--text-primary)] leading-tight">Selected Work</h1>
        <p class="font-serif italic text-[1.2rem] text-[var(--text-secondary)] mt-4">Selected work and experimental labs.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {mainProjects.map(p => <ProjectCard project={p} />)}
      </div>

      {frontendProjects.length > 0 && (
        <div class="mt-24 pt-16 border-t border-[var(--border)]">
          <div class="mb-10">
            <span class="section-label">More</span>
            <h2 class="font-display font-bold text-3xl text-[var(--text-primary)]">Other Works & Experiments</h2>
            <p class="text-sm text-[var(--text-muted)] mt-2 font-mono uppercase tracking-widest">Frontend experiments & templates.</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {frontendProjects.map(p => <ProjectCard project={p} />)}
          </div>
        </div>
      )}
    </div>
  </main>
</MainLayout>
