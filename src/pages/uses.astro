---
import MainLayout from "@layouts/MainLayout.astro";
import { Content as UsesMarkdown } from "../content/uses.md";
---

<MainLayout title="Uses">
    <main class="container mx-auto px-4 md:px-8 py-8 max-w-[800px]">
        <div class="section-label">Uses</div>
        <h1 class="page-heading">Uses</h1>
        <article class="prose prose-neutral dark:prose-invert w-full max-w-none prose-p:text-[var(--text-secondary)] prose-p:leading-[1.8] prose-li:text-[var(--text-secondary)] prose-headings:font-display prose-headings:font-bold prose-headings:text-[var(--text-primary)]">
            <UsesMarkdown />
        </article>
    </main>
</MainLayout>
